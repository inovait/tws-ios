os.TWS\/documentation\/TWS"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/tws\/remotesnippet"]}],"sections":[{"estimatedTimeInMinutes":3,"kind":"hero","title":"Display your first remote snippet","content":[{"inlineContent":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"type":"paragraph"}],"chapter":"Display your first snippet"},{"kind":"tasks","tasks":[{"stepsSection":[{"content":[{"inlineContent":[{"text":"Create a project on the TWS portal. Once completed, the next step is to integrate it into your app.","type":"text"}],"type":"paragraph"}],"caption":[{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Make sure to keep a reference to the project ID, as you will need it later in the setup and integration process."}]}]}],"media":null,"runtimePreview":null,"code":"RemoteSnippet_00.swift","type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Import the TWS module at the app’s entry point."}]}],"caption":[],"media":null,"runtimePreview":null,"code":"RemoteSnippet_01.swift","type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use one of the available methods to inject the manager into your view."}]}],"caption":[{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Under the hood, an instance of "},{"type":"codeVoice","code":"TWSManager"},{"type":"text","text":" is created and registered with the remote services, establishing a socket connection to the server and handling updates via an "},{"type":"codeVoice","code":"@Observable"},{"type":"text","text":" manager. If called multiple times, the same instance is shared instead of being recreated."}],"type":"paragraph"}]}],"media":null,"runtimePreview":null,"code":"RemoteSnippet_02.swift","type":"step"}],"anchor":"Connect-with-the-TWS-portal","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The fundamental building block for managing and interacting with snippets in TWS is creating and configuring a project on the "},{"type":"reference","isActive":true,"identifier":"https:\/\/thewebsnippet.com"},{"type":"text","text":". A project serves as the core unit for organizing and managing snippets, allowing you to structure and customize functionality for your application."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This includes retrieving your organization and project IDs, adding snippets to the project, modifying their properties, and integrating them seamlessly into your app. By managing these elements through the TWS portal, you can ensure consistency and scalability across your application’s features."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Most importantly, managing your snippets through the portal keeps the core logic and configuration independent from the app’s UI, making it easier to test, maintain, and reuse across different environments."}]}]}],"title":"Connect with the TWS portal"},{"stepsSection":[{"runtimePreview":null,"content":[{"inlineContent":[{"text":"Navigate to the view where you want to display the snippets.","type":"text"}],"type":"paragraph"}],"caption":[],"type":"step","code":"RemoteSnippet_03.swift","media":null},{"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Pull the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSManager"},{"type":"text","text":" from the environment."}],"type":"paragraph"}],"caption":[],"type":"step","code":"RemoteSnippet_04.swift","media":null},{"runtimePreview":null,"content":[{"inlineContent":[{"text":"Loop over all the snippets.","type":"text"}],"type":"paragraph"}],"caption":[{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"You will be notified about the changes when snippets are added, removed or updated."}],"type":"paragraph"}]}],"type":"step","code":"RemoteSnippet_05.swift","media":null},{"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Utilize the "},{"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView","isActive":true,"type":"reference"},{"type":"text","text":" to display the snippets within the view hierarchy."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the next tutorial to see all the ways to manager your TWSManager instance."}]}],"type":"step","code":"RemoteSnippet_06.swift","media":null}],"anchor":"Presenting-snippets","contentSection":[{"content":[{"inlineContent":[{"text":"After injecting it into the view, you can access the ","type":"text"},{"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSManager","type":"reference","isActive":true},{"text":" from anywhere in the view by retrieving it from the environment. Use the observable object to display snippets and listen for updates seamlessly.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"title":"Presenting snippets"}]},{"action":{"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"isActive":true,"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","overridingTitle":"Get started","type":"reference"},"kind":"callToAction","title":"Creating and managing TWSManager","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"featuredEyebrow":"Tutorial"}],"metadata":{"categoryPathComponent":"Tutorial-Table-of-Contents","title":"Display your first remote snippet","role":"project","category":"Lear