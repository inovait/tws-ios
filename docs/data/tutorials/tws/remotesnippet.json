te to the view where you want to display the snippets."}]}],"runtimePreview":null,"caption":[],"media":null,"code":"RemoteSnippet_03.swift","type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Pull the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSManager","type":"reference"},{"text":" from the environment.","type":"text"}]}],"runtimePreview":null,"caption":[],"media":null,"code":"RemoteSnippet_04.swift","type":"step"},{"content":[{"inlineContent":[{"text":"Loop over all the snippets.","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"caption":[{"content":[{"inlineContent":[{"type":"text","text":"You will be notified about the changes when snippets are added, removed or updated."}],"type":"paragraph"}],"name":"Note","type":"aside","style":"note"}],"media":null,"code":"RemoteSnippet_05.swift","type":"step"},{"content":[{"inlineContent":[{"type":"text","text":"Utilize the "},{"type":"reference","identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView","isActive":true},{"type":"text","text":" to display the snippets within the view hierarchy."}],"type":"paragraph"}],"runtimePreview":null,"caption":[{"inlineContent":[{"text":"Check the next tutorial to see all the ways to manager your TWSManager instance.","type":"text"}],"type":"paragraph"}],"media":null,"code":"RemoteSnippet_06.swift","type":"step"}]}],"kind":"tasks"},{"title":"Creating and managing TWSManager","action":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","isActive":true,"type":"reference","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"overridingTitle":"Get started"},"kind":"callToAction","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"featuredEyebrow":"Tutorial"}],"metadata":{"categoryPathComponent":"Tutorial-Table-of-Contents","title":"Display your first remote snippet","role":"project","category":"Learn to use the SDK"},"kind":"pro