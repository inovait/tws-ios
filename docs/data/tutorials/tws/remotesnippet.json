{"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"project","variants":[{"paths":["\/tutorials\/tws\/remotesnippet"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"category":"Learn to use the SDK","title":"Display your first remote snippet","categoryPathComponent":"Tutorial-Table-of-Contents","role":"project"},"sections":[{"estimatedTimeInMinutes":3,"chapter":"Display your first snippet","title":"Display your first remote snippet","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views."}]}],"kind":"hero"},{"tasks":[{"contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"text":"The fundamental building block for managing and interacting with snippets in TWS is creating and configuring a project on the ","type":"text"},{"identifier":"https:\/\/thewebsnippet.com","isActive":true,"type":"reference"},{"text":". A project serves as the core unit for organizing and managing snippets, allowing you to structure and customize functionality for your application.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This includes retrieving your organization and project IDs, adding snippets to the project, modifying their properties, and integrating them seamlessly into your app. By managing these elements through the TWS portal, you can ensure consistency and scalability across your application’s features.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Most importantly, managing your snippets through the portal keeps the core logic and configuration independent from the app’s UI, making it easier to test, maintain, and reuse across different environments.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing"}],"title":"Connect with the TWS portal","stepsSection":[{"media":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Create a project on the TWS portal. Once completed, the next step is to integrate it into your app.","type":"text"}]}],"code":"RemoteSnippet_00.swift","runtimePreview":null,"caption":[{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Make sure to keep a reference to the project ID, as you will need it later in the setup and integration process.","type":"text"}]}]}]},{"media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Import the TWS module at the app’s entry point."}],"type":"paragraph"}],"code":"RemoteSnippet_01.swift","runtimePreview":null,"caption":[]},{"media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Use one of the available methods to inject the manager into your view."}],"type":"paragraph"}],"code":"RemoteSnippet_02.swift","runtimePreview":null,"caption":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Under the hood, an instance of "},{"type":"codeVoice","code":"TWSManager"},{"type":"text","text":" is created and registered with the remote services, establishing a socket connection to the server and handling updates via an "},{"type":"codeVoice","code":"@Observable"},{"type":"text","text":" manager. If called multiple times, the same instance is shared instead of being recreated."}]}],"style":"note","type":"aside","name":"Note"}]}],"anchor":"Connect-with-the-TWS-portal"},{"contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"text":"After injecting it into the view, you can access the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSManager","type":"reference"},{"text":" from anywhere in the view by retrieving it from the environment. Use the observable object to display snippets and listen for updates seamlessly.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing"}],"title":"Presenting snippets","stepsSection":[{"code":"RemoteSnippet_03.swift","media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Navigate to the view where you want to display the snippets."}],"type":"paragraph"}],"caption":[],"runtimePreview":null},{"code":"RemoteSnippet_04.swift","media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Pull the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSManager"},{"type":"text","text":" from the environment."}],"type":"paragraph"}],"caption":[],"runtimePreview":null},{"code":"RemoteSnippet_05.swift","media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Loop over all the snippets."}],"type":"paragraph"}],"caption":[{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"You will be notified about the changes when snippets are added, removed or updated.","type":"text"}]}],"type":"aside"}],"runtimePreview":null},{"code":"RemoteSnippet_06.swift","media":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Utilize the "},{"isActive":true,"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView","type":"reference"},{"type":"text","text":" to display the snippets within the view hierarchy."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the next tutorial to see all the ways to manager your TWSManager instance."}]}],"runtimePreview":null}],"anchor":"Presenting-snippets"}],"kind":"tasks"},{"abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"featuredEyebrow":"Tutorial","action":{"type":"reference","overridingTitle":"Get started","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"isActive":true},"title":"Creating and managing TWSManager","kind":"callToAction"}],"hierarchy":{"modules":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents