{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/tws\/remotesnippet"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[{"chapter":"Display your first snippet","title":"Display your first remote snippet","kind":"hero","estimatedTimeInMinutes":3,"content":[{"type":"paragraph","inlineContent":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}]}]},{"tasks":[{"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"text":"The fundamental building block for managing and interacting with snippets in TWS is creating and configuring a project on the ","type":"text"},{"identifier":"https:\/\/thewebsnippet.com","isActive":true,"type":"reference"},{"text":". A project serves as the core unit for organizing and managing snippets, allowing you to structure and customize functionality for your application.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This includes retrieving your organization and project IDs, adding snippets to the project, modifying their properties, and integrating them seamlessly into your app. By managing these elements through the TWS portal, you can ensure consistency and scalability across your application’s features.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Most importantly, managing your snippets through the portal keeps the core logic and configuration independent from the app’s UI, making it easier to test, maintain, and reuse across different environments."}]}]}],"title":"Connect with the TWS portal","anchor":"Connect-with-the-TWS-portal","stepsSection":[{"media":null,"type":"step","runtimePreview":null,"caption":[{"name":"Note","type":"aside","style":"note","conten