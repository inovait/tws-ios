d and registered with the remote services, establishing a socket connection to the server and handling updates via an "},{"code":"@Observable","type":"codeVoice"},{"type":"text","text":" manager. If called multiple times, the same instance is shared instead of being recreated."}]}],"style":"note","name":"Note"}],"code":"RemoteSnippet_02.swift","type":"step","media":null}],"contentSection":[{"content":[{"inlineContent":[{"text":"The fundamental building block for managing and interacting with snippets in TWS is creating and configuring a project on the ","type":"text"},{"type":"reference","identifier":"https:\/\/thewebsnippet.com","isActive":true},{"text":". A project serves as the core unit for organizing and managing snippets, allowing you to structure and customize functionality for your application.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This includes retrieving your organization and project IDs, adding snippets to the project, modifying their properties, and integrating them seamlessly into your app. By managing these elements through the TWS portal, you can ensure consistency and scalability across your application’s features."}],"type":"paragraph"},{"inlineContent":[{"text":"Most importantly, managing your snippets through the portal keeps the core logic and configuration independent from the app’s UI, making it easier to test, maintain, and reuse across different environments.","type":"text"}],"type":"paragraph"}],"kind":"contentAndMedia","mediaPosition":"trailing"}]},{"anchor":"Presenting-snippets","title":"Presenting snippets","stepsSection":[{"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Navigate to the view where you want to display the snippets.","type":"text"}]}],"code":"RemoteSnippet_03.swift","type":"step","caption":[],"runtimePreview":null},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pull the "},{"type":"reference","identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSManager","isActive":true},{"type":"text","text":" from the environment."}]}],"code":"RemoteSnippet_04.swift","type":"step","caption":[],"runtimePreview":null},{"media":null,"content":[{"inlineContent":[{"type":"text","text":"Loop over all the snippets."}],"type":"paragraph"}],"code":"RemoteSnippet_05.swift","type":"step","caption":[{"content":[{"inlineContent":[{"text":"You will be notified about the changes when snippets are added, removed or updated.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"}],"runtimePreview":null},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Utilize the ","type":"text"},{"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView","isActive":true,"type":"reference"},{"text":" to display the snippets within the view hierarchy.","type":"text"}]}],"code":"RemoteSnippet_06.swift","type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the next tutorial to see all the ways to manager your TWSManager instance."}]}],"runtimePreview":null}],"contentSection":[{"content":[{"inlineContent":[{"text":"After injecting it into the view, you can access the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSManager"},{"text":" from anywhere in the view by retrieving it from the environment. Use the observable object to display snippets and listen for updates seamlessly.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia"}]}],"kind":"tasks"},{"action":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"overridingTitle":"Get started"},"abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"featuredEyebrow":"Tutorial","title":"Creating and managing TWSManager","kind":"callToAction"}