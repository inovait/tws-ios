type":"codeVoice"},{"text":" is created and registered with the remote services, establishing a socket connection to the server and handling updates via an ","type":"text"},{"code":"@Observable","type":"codeVoice"},{"text":" manager. If called multiple times, the same instance is shared instead of being recreated.","type":"text"}]}],"type":"aside"}]}],"title":"Connect with the TWS portal","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"text":"The fundamental building block for managing and interacting with snippets in TWS is creating and configuring a project on the ","type":"text"},{"identifier":"https:\/\/thewebsnippet.com","isActive":true,"type":"reference"},{"text":". A project serves as the core unit for organizing and managing snippets, allowing you to structure and customize functionality for your application.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This includes retrieving your organization and project IDs, adding snippets to the project, modifying their properties, and integrating them seamlessly into your app. By managing these elements through the TWS portal, you can ensure consistency and scalability across your application’s features.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Most importantly, managing your snippets through the portal keeps the core logic and configuration independent from the app’s UI, making it easier to test, maintain, and reuse across different environments.","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Presenting-snippets","stepsSection":[{"runtimePreview":null,"type":"step","media":null,"content":[{"inlineContent":[{"type":"text","text":"Navigate to the view where you want to display the snippets."}],"type":"paragraph"}],"caption":[],"code":"RemoteSnippet_03.swift"},{"runtimePreview":null,"type":"step","media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pull the "},{"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSManager","type":"reference","isActive":true},{"type":"text","text":" from the environment."}]}],"caption":[],"code":"RemoteSnippet_04.swift"},{"runtimePreview":null,"type":"step","media":null,"content":[{"inlineContent":[{"type":"text","text":"Loop over all the snippets."}],"type":"paragraph"}],"caption":[{"style":"note","content":[{"inlineContent":[{"text":"You will be notified about the changes when snippets are added, removed or updated.","type":"text"}],"type":"paragraph"}],"name":"Note","type":"aside"}],"code":"RemoteSnippet_05.swift"},{"runtimePreview":null,"type":"step","media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Utilize the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView","type":"reference"},{"text":" to display the snippets within the view hierarchy.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check the next tutorial to see all the ways to manager your TWSManager instance."}]}],"code":"RemoteSnippet_06.swift"}],"title":"Presenting snippets","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"After injecting it into the view, you can access the "},{"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSManager","type":"reference","isActive":true},{"type":"text","text":" from anywhere in the view by retrieving it from the environment. Use the observable object to display snippets and listen for updates seamlessly."}]}]}]}],"kind":"tasks"},{"title":"Creating and managing TWSManager","featuredEyebrow":"Tutorial","kind":"callToAction","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"action":{"type":"reference","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],