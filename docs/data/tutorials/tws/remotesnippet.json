{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[{"title":"Display your first remote snippet","chapter":"Display your first snippet","content":[{"type":"paragraph","inlineContent":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}]}],"kind":"hero","estimatedTimeInMinutes":3},{"tasks":[{"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"The fundamental building block for managing and interacting with snippets in TWS is creating and configuring a project on the "},{"type":"reference","identifier":"https:\/\/thewebsnippet.com","isActive":true},{"type":"text","text":". A project serves as the core unit for organizing and managing snippets, allowing you to structure and customize functionality for your application."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This includes retrieving your organization and project IDs, adding snippets to the project, modifying their properties, and integrating them seamlessly into your app. By managing these elements through the TWS portal, you can ensure consistency and scalability across your application’s features."}],"type":"paragraph"},{"inlineContent":[{"text":"Most importantly, managing your snippets through the portal keeps the core logic and configuration independent from the app’s UI, making it easier to test, maintain, and reuse across different environments.","type":"text"}],"type":"paragraph"}]}],"stepsSection":[{"caption":[{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Make sure to keep a reference to the project ID, as you will need it later in the setup and integration process."}]}],"style":"note","type":"aside"}],"media":null,"code":"RemoteSnippet_00.swift","type":"step","content":[{"inlineContent":[{"text":"Create a project on the TWS portal. Once completed, the next step is to integrate it into your app.","type":"text"}],"type":"paragraph"}],"runtimePreview":null},{"caption":[],"media":null,"code":"RemoteSnippet_01.swift","type":"step","content":[{"inlineContent":[{"text":"Import the TWS module at the app’s entry point.","type":"text"}],"type":"paragraph"}],"runtimePreview":null},{"caption":[{"name":"Note","content":[{"inlineContent":[{"text":"Under the hood, an instance of ","type":"text"},{"type":"codeVoice","code":"TWSManager"},{"text":" is created and registered with the remote services, establishing a socket connection to the server and handling updates via an ","type":"text"},{"type":"codeVoice","code":"@Observable"},{"text":" manager. If called multiple times, the same instance is shared instead of being recreated.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside"}],"media":null,"code":"RemoteSnippet_02.swift","type":"step","content":[{"inlineContent":[{"text":"Use one of the available methods to inject the manager into your view.","type":"text"}],"type":"paragraph"}],"runtimePreview":null}],"title":"Connect with the TWS portal","anchor":"Connect-with-the-TWS-portal"},{"contentSection":[{"mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"After injecting it into the view, you can access the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSManager"},{"type":"text","text":" from anywhere in the view by retrieving it from the environment. Use the observable object to display snippets and listen for updates seamlessly."}]}],"kind":"contentAndMedia"}],"stepsSection":[{"code":"RemoteSnippet_03.swift","content":[{"inlineContent":[{"text":"Navigate to the view where you want to display the snippets.","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"type":"step","caption":[],"media":null},{"code":"RemoteSnippet_04.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pull the "},{"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSManager","isActive":true,"type":"reference"},{"type":"text","text":" from the environment."}]}],"runtimePreview":null,"type":"step","caption":[],"media":null},{"code":"RemoteSnippet_05.swift","content":[{"type":"paragraph","inlineContent":[{"text":"Loop over all the snippets.","type":"text"}]}],"runtimePreview":null,"type":"step","caption":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You will be notified about the changes when snippets are added, removed or updated."}]}],"name":"Note","type":"aside","style":"note"}],"media":null},{"code":"RemoteSnippet_06.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Utilize the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView"},{"type":"text","text":" to display the snippets within the view hierarchy."}]}],"runtimePreview":null,"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"Check the next tutorial to see all the ways to manager your TWSManager instance.","type":"text"}]}],"media":null}],"title":"Presenting snippets","anchor":"Presenting-snippets"}],"kind":"tasks"},{"title":"Creating and managing TWSManager","action":{"isActive":true,"type":"reference","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"overridingTitle":"Get started"},"featuredEyebrow":"Tutorial","kind":"callToAction","abstract":[{"text":"Learn different ways of creating and managing TWSManager","type":"text"}]}],"metadata":{"title":"Display your first remote snippet","category":"Learn to use the SDK","categoryPathComponent":"Tutorial-Table-of-Contents","role":"project"},"kind":"project","identifier":{"url":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","doc:\/\/t