{"identifier":{"url":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch","interfaceLanguage":"swift"},"sections":[{"estimatedTimeInMinutes":5,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices."}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If you are exclusively using either remote or local handling for snippets, these additional considerations are not necessary."}]}]}],"kind":"hero","title":"Combine remote and local snippets","chapter":"Display your first snippet"},{"tasks":[{"title":"Mix & Match","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Let’s begin by displaying a few remote snippets, then integrate some local snippets, and finally switch back to remote ones."}]}]}],"stepsSection":[{"media":null,"type":"step","runtimePreview":null,"caption":[],"content":[{"inlineContent":[{"type":"text","text":"Start by enabling TWS by providing the Project identifiers."}],"type":"paragraph"}],"code":"MixAndMatch_00.swift"},{"media":null,"type":"step","runtimePreview":null,"caption":[],"content":[{"inlineContent":[{"text":"Show all of the remote snippets in the ","type":"text"},{"code":"TabView","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"code":"MixAndMatch_01.swift"},{"media":null,"type":"step","runtimePreview":null,"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Now, let’s imagine there is a developer tool hosted on a specific site that allows us to control a snippet, but this tool is not returned from the server. In this case, we can pair the snippet with the developer tool by displaying them side-by-side. This approach allows developers to interact with and control the snippet in real time while viewing it within the application.","type":"text"}]}],"code":"MixAndMatch_02.swift"},{"media":null,"type":"step","runtimePreview":null,"caption":[{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"Once you take over, all ancestor views are treated as local snippets. If you need to use remote snippets again, you must call "},{"type":"codeVoice","code":".twsLocal(false)"},{"type":"text","text":" to restore the default behavior."}],"type":"paragraph"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"Because the manager is injected into the view and all its ancestor views, the SDK assumes that the snippet should be handled in correspondence with the remotely hosted snippet. To override this behavior, we need to explicitly inform the system that we are taking over from this point forward.","type":"text"}]}],"code":"MixAndMatch_03.swift"},{"media":null,"type":"step","runtimePreview":null,"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Now, if we want to use remote snippets again, we’ll need to switch back to remote handling.","type":"text"}]}],"code":"MixAndMatch_04.swift"}],"anchor":"Mix-Match"}],"kind":"tasks"},{"action":{"overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"type":"reference","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","isActive":true},"abstract":[{"text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base.","type":"text"}],"kind":"callToAction","featuredEyebrow":"Tutorial","title":"Integrating TWSNotifications with your notifications"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"categoryPat