push notification code base."}],"role":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","estimatedTime":"3min","kind":"project","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet":{"type":"topic","role":"project","kind":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet","title":"Display your first remote snippet","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"url":"\/tutorials\/tws\/remotesnippet","estimatedTime":"3min"},"doc://tws-ios.TWS/tutorials/TWS/Notifications#Integrating-TWSNotifications":{"title":"Integrating TWSNotifications","role":"pseudoSymbol","kind":"section","abstract":[{"type":"text","text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications#Integrating-TWSNotifications","url":"\/tutorials\/tws\/notifications#Integrating-TWSNotifications","type":"section"},"CustomizingViews_02.swift":{"type":"file","content":["import Foundation","import SwiftUI","","struct ErrorView: View {","    var error: Error","    ","    var body: some View {","        VStack {","            Image(systemName: \"exclamationmark.triangle\")","                .padding(.bottom)","            Text(error.localizedDescription)","                ","        }","        .frame(width: 300)","        .padding()","        .background(Color.red)","        .foregroundStyle(.white)","        .clipShape(RoundedRectangle(cornerRadius: 16))","    }","}"],"highlights":[],"syntax":"swift","fileName":"ErrorView.swift","identifier":"CustomizingViews_02.swift","fileType":"swift"}}}