{"sections":[{"kind":"hero","title":"Customize views to fit your application","content":[{"inlineContent":[{"text":"Learn how to customize your view to fit your applications profile.","type":"text"},{"text":" ","type":"text"},{"text":"Customize loading, preloading and error views.","type":"text"}],"type":"paragraph"}],"chapter":"Customizing TWSView","estimatedTimeInMinutes":3},{"tasks":[{"contentSection":[{"mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"In this tutorial you will learn how to inject custom views into TWSView to customize loading and error screens."}],"type":"paragraph"}],"kind":"contentAndMedia"}],"title":"Custom loading and error views","stepsSection":[{"caption":[],"media":null,"content":[{"inlineContent":[{"type":"text","text":"First lets display a snippet."}],"type":"paragraph"}],"code":"CustomizingViews_00.swift","type":"step","runtimePreview":null},{"caption":[],"media":null,"content":[{"inlineContent":[{"text":"Lets create a view that will be displayed while the page is loading.","type":"text"}],"type":"paragraph"}],"code":"CustomizingViews_01.swift","type":"step","runtimePreview":null},{"caption":[],"media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"And now a view for the errors."}]}],"code":"CustomizingViews_02.swift","type":"step","runtimePreview":null},{"caption":[{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"We used LoadingView for both loadingView and preloadingView, because it is best if these two are the same."}]}]}],"media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now to bring it all together we will bind these two views to TWSView, which will enable them to be used when snippet is reporting an error or being loaded into the frame."}]}],"code":"CustomizingViews_03.swift","type":"step","runtimePreview":null}],"anchor":"Custom-loading-and-error-views"}],"kind":"tasks"},{