faceLanguage":"swift","url":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/tws\/customizingviews"]}],"sections":[{"chapter":"Customizing TWSView","content":[{"inlineContent":[{"text":"Learn how to customize your view to fit your applications profile.","type":"text"},{"type":"text","text":" "},{"text":"Customize loading, preloading and error views.","type":"text"}],"type":"paragraph"}],"estimatedTimeInMinutes":3,"kind":"hero","title":"Customize views to fit your application"},{"kind":"tasks","tasks":[{"contentSection":[{"mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"text":"In this tutorial you will learn how to inject custom views into TWSView to customize loading and error screens.","type":"text"}]}],"kind":"contentAndMedia"}],"title":"Custom loading and error views","stepsSection":[{"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"First lets display a snippet.","type":"text"}]}],"caption":[],"media":null,"type":"step","code":"CustomizingViews_00.swift"},{"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Lets create a view that will be displayed while the page is loading."}],"type":"paragraph"}],"caption":[],"media":null,"type":"step","code":"CustomizingViews_01.swift"},{"media":null,"code":"CustomizingViews_02.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"And now a view for the errors."}]}],"runtimePreview":null,"type":"step","caption":[]},{"type":"step","runtimePreview":null,"content":[{"inlineContent":[{"text":"Now to bring it all together we will bind these two views to TWSView, which will enable them to be used when snippet is reporting an error or being loaded into the frame.","type":"text"}],"type":"paragraph"}],"caption":[{"style":"note","name":"Note","content":[{"inlineContent":[{"text":"We used LoadingView for both loadingView and preloadingView, because it is best if these two are the same.","type":"text"}],"type":"paragraph"}],"type":"aside"}],"media":null,"code":"CustomizingViews_03.swift"}],"anchor":"Custom-loading-and-error-views"}]},{"kind":"callToAction","abstract":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"action":{"type":"reference","overridingTitle":"Get started","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Get started"}]},"title":"Intercepting URL requests","featuredEyebrow":"Tutorial"}],"metadata":{"category":"Learn to use the SDK","role":"project","categoryPathComponent":"Tutorial-Table-of-Contents","title":"Customize views to fit your application"},"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor#Custom-interceptors":{"title":"Custom interceptors","url":"\/tutorials\/tws\/custominterceptor#Custom-interceptors","abstract":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"kind":"section","role":"pseudoSymbol","type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Presenting-snippets":{"role":"pseudoSymbol","abstract":[{"type":"text","text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Presenting-snippets","kind":"section","title":"Presenting snippets","type":"section","url":"\/tutorials\/tws\/remotesnippet#Presenting-snippets"},"CustomizingViews_01.swift":{"fileName":"LoadingView.swift","identifier":"CustomizingViews_01.swift","type":"file","content":["import Foundation","import SwiftUI","","struct LoadingView: View {","    var body: some View {","        ZStack {","            Color.green","            ProgressView()","                .frame(width: 200, height: 200)","                .background(.blue)","        }","    }","}"],"syntax":"swift","highlights":[],"fileType":"swift"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch":{"title":"Combine remote and local snippets","kind":"project","role":"project","estimatedTime":"5min","type":"topic","abstract":[{"text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices.","type":"text"}],"url":"\/tutorials\/tws\/mixandmatch","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet":{"title":"Display your first local snippet","kind":"project","role":"project","estimatedTime":"2min","type":"topic","abstract":[{"text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content.","type":"text"}],"url":"\/tutorials\/tws\/localsnippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet#Displaying-a-Snippet":{"role":"pseudoSymbol","abstract":[{"type":"text","text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet","kind":"section","title":"Displaying a Snippet","type":"section","url":"\/tutorials\/tws\/localsnippet#Displaying-a-Snippet"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Display-your-first-snippet":{"role":"article","abstract":[],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet","kind":"article","title":"Display your first snippet","type":"topic","url":"\/tutorials\/tutorial-table-of-contents\/display-your-first-snippet"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor":{"role":"project","estimatedTime":"5min","abstract":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor","kind":"project","title":"Intercepting URL requests","type":"topic","url":"\/tutorials\/tws\/custominterceptor"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Connect-with-the-TWS-portal":{"role":"pseudoSymbol","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal","kind":"section","title":"Connect with the TWS portal","type":"section","url":"\/tutorials\/tws\/remotesnippet#Connect-with-the-TWS-portal"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch#Mix-Match":{"title":"Mix & Match","url":"\/tutorials\/tws\/mixandmatch#Mix-Match","abstract":[{"type":"text","text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices."}],"kind":"section","role":"pseudoSymbol","type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch#Mix-Match"},"doc://tws-ios.TWS/tutorials/TWS/Notifications#Integrating-TWSNotifications":{"role":"pseudoSymbol","abstract":[{"type":"text","text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications#Integrating-TWSNotifications","kind":"section","title":"Integrating TWSNotifications","type":"section","url":"\/tutorials\/tws\/notifications#Integrating-TWSNotifications"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation":{"role":"project","estimatedTime":"5min","abstract":[{"text":"Learn different ways of creating and managing TWSManager","type":"text"}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","kind":"project","title":"Creating and managing TWSManager","type":"topic","url":"\/tutorials\/tws\/managercreation"},"doc://tws-ios.TWS/tutorials/TWS/Notifications":{"role":"project","estimatedTime":"3min","abstract":[{"type":"text","text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","kind":"project","title":"Integrating TWSNotifications with your notifications","type":"topic","url":"\/tutorials\/tws\/notifications"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Customizing-TWSView":{"role":"article","abstract":[],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView","kind":"article","title":"Customizing TWSView","type":"topic","url":"\/tutorials\/tutorial-table-of-contents\/customizing-twsview"},"CustomizingViews_03.swift":{"fileName":"CustomView.swift","identifier":"CustomizingViews_03.swift","type":"file","content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    ","    var body : some View {","        TWSView(snippet: mySnippet)","            .twsBind(loadingView: { AnyView(LoadingView()) })","            .twsBind(preloadingView: { AnyView(LoadingView()) })","            .twsBind(errorView: { error in AnyView(ErrorView(error: error))})","    }","}"],"syntax":"swift","highlights":[],"fileType":"swift"},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews#Custom-loading-and-error-views":{"role":"pseudoSymbol","abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews#Custom-loading-and-error-views","kind":"section","title":"Custom loading and error views","type":"section","url":"\/tutorials\/tws\/customizingviews#Custom-loading-and-error-views"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation#Manager-creation-and-registration":{"title":"Manager creation and registration","url":"\/tutorials\/tws\/managercreation#Manager-creation-and-registration","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"kind":"section","role":"pseudoSymbol","type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet":{"title":"Display your first remote snippet","kind":"project","role":"project","estimatedTime":"3min","type":"topic","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"url":"\/tutorials\/tws\/remotesnippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet"},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews":{"role":"project","estimatedTime":"3min","abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews","kind":"project","title":"Customize views to fit your application","type":"topic","url":"\/tutorials\/tws\/customizingviews"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents":{"role":"overview","abstract":[{"text":"Follow the tutorials to learn how to use the SDK for displaying snippets.","type":"text"}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","kind":"overview","title":"Getting Started","type":"topic","url":"\/tutorials\/tutorial-table-of-contents"},"CustomizingViews_00.swift":{"fileName":"CustomView.swift","type":"file","identifier":"CustomizingViews_00.swift","content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    ","    var body : some View {","        TWSView(snippet: mySnippet)","    }","}"],"syntax":"swift","highlights":[],"fileType":"swift"},"CustomizingViews_02.swift":{"fileName":"ErrorView.swift","type":"file","identifier":"CustomizingViews_02.swift","content":["import Foundation","import SwiftUI","","struct ErrorView: View {","    var error: Error","    ","    var body: some View {","        VStack {","            Image(systemName: \"exclamationmark.triangle\")","                .padding(.bottom)","            Text(error.localizedDescription)","                ","        }","        .frame(width: 300)","        .padding()","        .background(Color.red)","        .foregroundStyle(.white)","        .clipShape(RoundedRectangle(cornerRadius: 16))","    }","}"],"syntax":"swift","highlights":[],"fileType":"swift"}}}