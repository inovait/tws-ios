[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"title":"Custom interceptors","type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors","url":"\/tutorials\/tws\/custominterceptor#Custom-interceptors","kind":"section"},"CustomizingViews_02.swift":{"syntax":"swift","identifier":"CustomizingViews_02.swift","content":["import Foundation","import SwiftUI","","struct ErrorView: View {","    var error: Error","    ","    var body: some View {","        VStack {","            Image(systemName: \"exclamationmark.triangle\")","                .padding(.bottom)","            Text(error.localizedDescription)","                ","        }","        .frame(width: 300)","        .padding()","        .background(Color.red)","        .foregroundStyle(.white)","        .clipShape(RoundedRectangle(cornerRadius: 16))","    }","}"],"highlights":[],"fileType":"swift","fileName":"ErrorView.swift","type":"file"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet#Displaying-a-Snippet":{"title":"Displaying a Snippet","type":"section","role":"pseudoSymbol","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet","url":"\/tutorials\/tws\/localsnippet#Displaying-a-Snippet","kind":"section","abstract":[{"type":"text","text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content."}]},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents":{"abstract":[{"text":"Follow the tutorials to learn how to use the SDK for displaying snippets.","type":"text"}],"role":"overview","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","title":"Getting Started","url":"\/tutorials\/tutorial-table-of-contents","kind":"overview","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor","role":"project","estimatedTime":"5min","abstract":[{"text":"Learn how to intercept desired URLs and use them in native flows","type":"text"}],"kind":"project","url":"\/tutorials\/tws\/custominterceptor","type":"topic","title":"Intercepting URL requests"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation":{"role":"project","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","url":"\/tutorials\/tws\/managercreation","type":"topic","kind":"project","title":"Creating and managing TWSManager","estimatedTime":"5min"},"CustomizingViews_03.swift":{"identifier":"CustomizingViews_03.swift","highlights":[],"fileType":"swift","type":"file","syntax":"swift","content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    ","    var body : some View {","        TWSView(snippet: mySnippet)","            .twsBind(loadingView: { AnyView(LoadingView()) })","            .twsBind(preloadingView: { AnyView(LoadingView()) })","            .twsBind(errorView: { error in AnyView(ErrorView(error: error))})","    }","}"],"fileName":"CustomView.swift"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch":{"url":"\/tutorials\/tws\/mixandmatch","type":"topic","estimatedTime":"5min","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch","title":"Combine remote and local snippets","abstract":[{"text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices.","type":"text"}],"role":"project","kind":"project"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Display-your-first-snippet":{"url":"\/tutorials\/tutorial-table-of-contents\/display-your-first-snippet","kind":"article","role":"article","abstract":[],"title":"Display your first snippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet":{"type":"topic","url":"\/tutorials\/tws\/remotesnippet","title":"Display your first remote snippet","kind":"project","role":"project","estimatedTime":"3min","abstract":[{"type":"text","text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet"},"doc://tws-ios.TWS/tutorials/TWS/Notifications":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","url":"\/tutorials\/tws\/notifications","role":"project","title":"Integrating TWSNotifications with your notifications","estimatedTime":"3min","abstract":[{"text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base.","type":"text"}],"type":"topic","kind":"project"},"CustomizingViews_01.swift":{"syntax":"swift","identifier":"CustomizingViews_01.swift","content":["import Foundation","import SwiftUI","","struct LoadingView: View {","    var body: some View {","        ZStack {","            Color.green","            ProgressView()","                .frame(width: 200, height: 200)","                .background(.blue)","        }","    }","}"],"highlights":[],"fileType":"swift","fileName":"LoadingView.swift","type":"file"}}}