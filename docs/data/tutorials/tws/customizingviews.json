TimeInMinutes":3,"chapter":"Customizing TWSView","title":"Customize views to fit your application","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}]}]},{"kind":"tasks","tasks":[{"anchor":"Custom-loading-and-error-views","stepsSection":[{"code":"CustomizingViews_00.swift","runtimePreview":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"First lets display a snippet."}],"type":"paragraph"}],"caption":[],"media":null},{"code":"CustomizingViews_01.swift","runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Lets create a view that will be displayed while the page is loading.","type":"text"}]}],"caption":[],"media":null},{"runtimePreview":null,"caption":[],"content":[{"inlineContent":[{"type":"text","text":"And now a view for the errors."}],"type":"paragraph"}],"code":"CustomizingViews_02.swift","media":null,"type":"step"},{"caption":[{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"We used LoadingView for both loadingView and preloadingView, because it is best if these two are the same.","type":"text"}]}]}],"media":null,"code":"CustomizingViews_03.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now to bring it all together we will bind these two views to TWSView, which will enable them to be used when snippet is reporting an error or being loaded into the frame."}]}],"type":"step","runtimePreview":null}],"title":"Custom loading and error views","contentSection":[{"content":[{"inlineContent":[{"text":"In this tutorial you will learn how to inject custom views into TWSView to customize loading and error screens.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia"}]}]},{"action":{"isActive":true,"overridingT