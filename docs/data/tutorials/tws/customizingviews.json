g a Snippet","role":"pseudoSymbol","kind":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet","url":"\/tutorials\/tws\/localsnippet#Displaying-a-Snippet"},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews":{"abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"text":"Customize loading, preloading and error views.","type":"text"}],"type":"topic","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews","role":"project","title":"Customize views to fit your application","kind":"project","estimatedTime":"3min","url":"\/tutorials\/tws\/customizingviews"},"CustomizingViews_01.swift":{"type":"file","fileType":"swift","highlights":[],"content":["import Foundation","import SwiftUI","","struct LoadingView: View {","    var body: some View {","        ZStack {","            Color.green","            ProgressView()","                .frame(width: 200, height: 200)","                .background(.blue)","        }","    }","}"],"fileName":"LoadingView.swift","identifier":"CustomizingViews_01.swift","syntax":"swift"},"CustomizingViews_03.swift":{"type":"file","content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    ","    var body : some View {","        TWSView(snippet: mySnippet)","            .twsBind(loadingView: { AnyView(LoadingView()) })","            .twsBind(preloadingView: { AnyView(LoadingView()) })","            .twsBind(errorView: { error in AnyView(ErrorView(error: error))})","    }","}"],"identifier":"CustomizingViews_03.swift","syntax":"swift","highlights":[],"fileType":"swift","fileName":"CustomView.swift"}}}