-and-error-views","title":"Custom loading and error views","type":"section","abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}],"url":"\/tutorials\/tws\/customizingviews#Custom-loading-and-error-views","kind":"section"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Connect-with-the-TWS-portal":{"url":"\/tutorials\/tws\/remotesnippet#Connect-with-the-TWS-portal","kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal","type":"section","title":"Connect with the TWS portal","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}]},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents":{"url":"\/tutorials\/tutorial-table-of-contents","role":"overview","kind":"overview","abstract":[{"type":"text","text":"Follow the tutorials to learn how to use the SDK for displaying snippets."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","type":"topic","title":"Getting Started"},"CustomizingViews_02.swift":{"highlights":[],"syntax":"swift","identifier":"CustomizingViews_02.swift","content":["import Foundation","import SwiftUI","","struct ErrorView: View {","    var error: Error","    ","    var body: some View {","        VStack {","            Image(systemName: \"exclamationmark.triangle\")","                .padding(.bottom)","            Text(error.localizedDescription)","                ","        }","        .frame(width: 300)","        .padding()","        .background(Color.red)","        .foregroundStyle(.white)","        .clipShape(RoundedRectangle(cornerRadius: 16))","    }","}"],"type":"file","fileName":"ErrorView.swift","fileType":"swift"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet