{"type":"topic","url":"\/tutorials\/tws\/notifications","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","kind":"project","title":"Integrating TWSNotifications with your notifications","role":"project","estimatedTime":"3min","abstract":[{"type":"text","text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base."}]},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet#Displaying-a-Snippet":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet","abstract":[{"type":"text","text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content."}],"url":"\/tutorials\/tws\/localsnippet#Displaying-a-Snippet","role":"pseudoSymbol","title":"Displaying a Snippet","kind":"section","type":"section"},"CustomizingViews_02.swift":{"identifier":"CustomizingViews_02.swift","fileType":"swift","fileName":"ErrorView.swift","type":"file","highlights":[],"syntax":"swift","content":["import Foundation","import SwiftUI","","struct ErrorView: View {","    var error: Error","    ","    var body: some View {","        VStack {","            Image(systemName: \"exclamationmark.triangle\")","                .padding(.bottom)","            Text(error.localizedDescription)","                ","        }","        .frame(width: 300)","        .padding()","        .background(Color.red)","        .foregroundStyle(.white)","        .clipShape(RoundedRectangle(cornerRadius: 16))","    }","}"]},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Display-your-first-snippet":{"type":"topic","url":"\/tutorials\/tutorial-table-of-contents\/display-your-first-snippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet","kind":"article","title":"Display your first snippet","role":"article","abstract":[]},"CustomizingViews_01.swift":{"type":"file","syntax":"swift","fileType":"swift","identifier":"CustomizingViews_01.swift","content":["import Foundation","import SwiftUI","","struct LoadingView: View {","    var body: some View {","        ZStack {","            Color.green","            ProgressView()","                .frame(width: 200, height: 200)","                .background(.blue)","        }","    }","}"],"fileName":"LoadingView.swift","highlights":[]},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Customizing-TWSView":{"type":"topic","url":"\/tutorials\/tutorial-table-of-contents\/customizing-twsview","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView","kind":"article","title":"Customizing TWSView","role":"article","abstract":[]},"CustomizingViews_00.swift":{"identifier":"CustomizingViews_00.swift","fileType":"swift","fileName":"CustomView.swift","type":"file","highlights":[],"syntax":"swift","content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    ","    var body : some View {","        TWSView(snippet: mySnippet)","    }","}"]},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet":{"type":"topic","url":"\/tutorials\/tws\/remotesnippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet","kind":"project","title":"Display your first remote snippet","role":"project","estimatedTime":"3min","abstract":[{"type":"text","text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views."}]},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents":{"type":"topic","url":"\/tutorials\/tutorial-table-of-contents","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","kind":"overview","title":"Gett