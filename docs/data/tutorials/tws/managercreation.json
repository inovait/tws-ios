"}],"role":"project","kind":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation":{"url":"\/tutorials\/tws\/managercreation","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"kind":"project","estimatedTime":"5min","title":"Creating and managing TWSManager","role":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet#Displaying-a-Snippet":{"type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet","title":"Displaying a Snippet","role":"pseudoSymbol","url":"\/tutorials\/tws\/localsnippet#Displaying-a-Snippet","kind":"section","abstract":[{"text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content.","type":"text"}]},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet","url":"\/tutorials\/tws\/localsnippet","kind":"project","estimatedTime":"2min","abstract":[{"type":"text","text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content."}],"type":"topic","title":"Display your first local snippet","role":"project"},"doc://tws-ios.TWS/tutorials/TWS/Notifications":{"url":"\/tutorials\/tws\/notifications","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","kind":"project","role":"project","title":"Integrating TWSNotifications with your notifications","abstract":[{"text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base.","type":"text"}],"estimatedTime":"3min","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation#Manager-creation-and-registration":{"title":"Manager creation and registration","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"url":"\/tutorials\/tws\/managercreation#Manager-creation-and-registration","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration","type":"section","kind":"section","role":"pseudoSymbol"},"ManagerCreation_01.swift":{"content":["import SwiftUI","import TWS","","struct ContentView: View {","    var body: some View {","        HomeView()","            .twsRegister(configuration: TWSBasicConfiguration(id: \"projectId\"))","    }","}","","struct HomeView: View {","    @Environment(TWSManager.self) var manager","    var body: some View {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }","        }","    }","}"],"fileName":"ContentView.swift","type":"file","highlights":[{"line":5},{"line":6},{"line":7},{"line":8},{"line":9},{"line":10},{"line":11},{"line":12},{"line":13}],"fileType":"swift","identifier":"ManagerCreation_01.swift","syntax":"swift"},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews":{"role":"project","abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}],"title":"Customize views to fit your application","type":"topic","url":"\/tutorials\/tws\/customizingviews","kind":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews","estimatedTime":"3min"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Display-your-first-snippet":{"url":"\/tutorials\/tutorial-table-of-contents\/display-your-first-snippet","role":"article","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet","title":"Display your first snippet","type":"topic","abstract":[],"kind":"article"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch#Mix-Match":{"kind":"section","url":"\/tutorials\/tws\/mixandmatch#Mix-Match","type":"section","abstract":[{"type":"text","text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices."}],"role":"pseudoSymbol","title":"Mix & Match","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch#Mix-Match"},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews#Custom-loading-and-error-views":{"title":"Custom loading and error views","abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}],"type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews#Custom-loading-and-error-views","role":"pseudoSymbol","url":"\/tutorials\/tws\/customizingviews#Custom-loading-and-error-views","kind":"section"},"ManagerCreation_00.swift":{"highlights":[],"content":["import SwiftUI","import TWS","","struct ContentView: View {","    \/\/ Create snippet with TWSFactory","    @State var manager = TWSFactory.new(with: TWSBasicConfiguration(id: \"projectId\"))","    ","    var body: some {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }","        }.onAppear {","            \/\/ Register manager with remote services","            manager.registerManager()","        }","    }","}"],"identifier":"ManagerCreation_00.swift","type":"file","syntax":"swift","fileType":"swift","fileName":"ContentView.swift"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Presenting-snippets":{"url":"\/tutorials\/tws\/remotesnippet#Presenting-snippets","kind":"section","role":"pseudoSymbol","abstract":[{"type":"text","text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Presenting-snippets","type":"section","title":"Presenting snippets"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents":{"url":"\/tutorials\/tutorial-table-of-contents","role":"overview","title":"Getting Started","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","kind":"overview","type":"topic","abstract":[{"type":"text","text":"Follow the tutorials to learn how to use the SDK for displaying snippets."}]},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Connect-with-the-TWS-portal":{"title":"Connect with the TWS portal","kind":"section","role":"pseudoSymbol","type":"section","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"url":"\/tutorials\/tws\/remotesnippet#Connect-with-the-TWS-portal","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal"},"doc://tws-ios.TWS/tutorials/TWS/Notifications#Integrating-TWSNotifications":{"type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications#Integrating-TWSNotifications","abstract":[{"text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base.","type":"text"}],"title":"Integrating TWSNotifications","kind":"section","url":"\/tutorials\/tws\/notifications#Integrating-TWSNotifications","role":"pseudoSymbol"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor#Custom-interceptors":{"kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors","type":"section","abstract":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"title":"Custom interceptors","url":"\/tutorials\/tws\/custominterceptor#Custom-interceptors"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Customizing-TWSView":{"kind":"article","url":"\/tutorials\/tutorial-table-of-contents\/customizing-twsview","type":"topic","role":"article","title":"Customizing TWSView","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView","abstract":[]},"ManagerCreation_02.swift":{"content":["import SwiftUI","import TWS","","struct ContentView: View {","    @State var manager = TWSFactory.new(with: TWSBasicConfiguration(id: \"projectId\"))","    var body: some View {","        HomeView()","            .twsRegister(using: manager)","    }","}","","struct HomeView: View {","    @Environment(TWSManager.self) var manager","    var body: some View {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }","        }","    }","}"],"fileName":"ContentView.swift","identifier":"ManagerCreation_02.swift","type":"file","highlights":[{"line":5},{"line":8}],"syntax":"swift","fileType":"swift"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet":{"abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"kind":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet","url":"\/tutorials\/tws\/remotesnippet","title":"Display your first remote snippet","role":"project","estimatedTime":"3min","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch":{"estimatedTime":"5min","kind":"project","type":"topic","abstract":[{"type":"text","text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices."}],"title":"Combine remote and local snippets","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch","role":"project","url":"\/tutorials\/tws\/mixandmatch"}}}