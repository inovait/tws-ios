dMatch#Mix-Match"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet":{"url":"\/tutorials\/tws\/localsnippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet","role":"project","estimatedTime":"2min","title":"Display your first local snippet","type":"topic","abstract":[{"text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content.","type":"text"}],"kind":"project"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation#Manager-creation-and-registration":{"abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"kind":"section","url":"\/tutorials\/tws\/managercreation#Manager-creation-and-registration","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration","type":"section","title":"Manager creation and registration","role":"pseudoSymbol"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Presenting-snippets":{"url":"\/tutorials\/tws\/remotesnippet#Presenting-snippets","kind":"section","title":"Presenting snippets","type":"section","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"role":"pseudoSymbol","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Presenting-snippets"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents":{"kind":"overview","url":"\/tutorials\/tutorial-table-of-contents","title":"Getting Started","role":"overview","abstract":[{"text":"Follow the tutorials to learn how to use the SDK for displaying snippets.","type":"text"}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","type":"topic"},"ManagerCreation_01.swift":{"fileName":"ContentView.swift","syntax":"swift","content":["import SwiftUI","import TWS","","struct ContentView: View {","    var body: some View {","        HomeView()","            .twsRegister(configuration: TWSBasicConfiguration(id: \"projectId\"))","    }","}","","struct HomeView: View {","    @Environment(TWSManager.self) var manager","    var body: some View {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }","        }","    }","}"],"fileType":"swift","highlights":[{"line":5},{"line":6},{"line":7},{"line":8},{"line":9},{"line":10},{"line":11},{"line":12},{"line":13}],"type":"file","identifier":"ManagerCreation_01.swift"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor#Custom-interceptors":{"kind":"section","abstract":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"type":"section","title":"Custom interceptors","role":"pseudoSymbol","url":"\/tutorials\/tws\/custominterceptor#Custom-interceptors","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet#Displaying-a-Snippet":{"title":"Displaying a Snippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet","type":"section","kind":"section","abstract":[{"type":"text","text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content."}],"role":"pseudoSymbol","url":"\/tutorials\/tws\/localsnippet#Displaying-a-Snippet"},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews":{"kind":"project","role":"project","type":"topic","estimatedTime":"3min","abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}],"title":"Customize views to fit your application","url":"\/tutorials\/tws\/customizingviews","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation":{"url":"\/tutorials\/tws\/managercreation","type":"topic","estimatedTime":"5min","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"role":"project","kind":"project","title":"Creating and managing TWSManager","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Connect-with-the-TWS-portal":{"role":"pseudoSymbol","title":"Connect with the TWS portal","type":"section","kind":"section","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"url":"\/tutorials\/tws\/remotesnippet#Connect-with-the-TWS-portal","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal"},"ManagerCreation_00.swift":{"fileName":"ContentView.swift","identifier":"ManagerCreation_00.swift","type":"file","fileType":"swift","highlights":[],"content":["import SwiftUI","import TWS","","struct ContentView: View {","    \/\/ Create snippet with TWSFactory","    @State var manager = TWSFactory.new(with: TWSBasicConfiguration(id: \"projectId\"))","    ","    var body: some {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }","        }.onAppear {","            \/\/ Register manager with remote services","            manager.registerManager()","        }","    }","}"],"syntax":"swift"},"ManagerCreation_02.swift":{"content":["import SwiftUI","import TWS","","struct ContentView: View {","    @State var manager = TWSFactory.new(with: TWSBasicConfiguration(id: \"projectId\"))","    var body: some View {","        HomeView()","            .twsRegister(using: manager)","    }","}","","struct HomeView: View {","    @Environment(TWSManager.self) var manager","    var body: some View {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }","        }","    }","}"],"syntax":"swift","fileType":"swift","fileName":"ContentView.swift","type":"file","identifier":"ManagerCreation_02.swift","highlights":[{"line":5},{"line":8}]},"doc://tws-ios.TWS/tutorials/TWS/Notifications#Integrating-TWSNotifications":{"abstract":[{"text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base.","type":"text"}],"url":"\/tutorials\/tws\/notifications#Integrating-TWSNotifications","role":"pseudoSymbol","type":"section","kind":"section","title":"Integrating TWSNotifications","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications#Integrating-TWSNotifications"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor":{"type":"topic","abstract":[{"text":"Learn how to intercept desired URLs and use them in native flows","type":"text"}],"kind":"project","title":"Intercepting URL requests","url":"\/tutorials\/tws\/custominterceptor","estimatedTime":"5min","role":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Customizing-TWSView":{"role":"article","kind":"article","abstract":[],"url":"\/tutorials\/tutorial-table-of-contents\/customizing-twsview","title":"Customizing TWSView","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet":{"kind":"project","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"type":"topic","url":"\/tutorials\/tws\/remotesnippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet","role":"project","estimatedTime":"3min","title":"Display your first remote snippet"},"doc://tws-ios.TWS/tutorials/TWS/Notifications":{"kind":"project","title":"Integrating TWSNotifications with your notifications","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","abstract":[{"text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base.","type":"text"}],"url":"\/tutorials\/tws\/notifications","type":"topic","estimatedTime":"3min","role":"project"}}}