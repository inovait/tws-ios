."}],"estimatedTime":"2min","type":"topic","url":"\/tutorials\/tws\/localsnippet","kind":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet","title":"Display your first local snippet"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation#Manager-creation-and-registration":{"title":"Manager creation and registration","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration","role":"pseudoSymbol","type":"section","url":"\/tutorials\/tws\/managercreation#Manager-creation-and-registration","kind":"section"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation":{"type":"topic","url":"\/tutorials\/tws\/managercreation","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","kind":"project","title":"Creating and managing TWSManager","role":"project","estimatedTime":"5min","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}]},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Connect-with-the-TWS-portal":{"type":"section","url":"\/tutorials\/tws\/remotesnippet#Connect-with-the-TWS-portal","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal","kind":"section","title":"Connect with the TWS portal","role":"pseudoSymbol","abstract":[{"type":"text","text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views."}]},"ManagerCreation_01.swift":{"content":["import SwiftUI","import TWS","","struct ContentView: View {","    var body: some View {","        HomeView()","            .twsRegister(configuration: TWSBasicConfiguration(id: \"projectId\"))","    }","}","","struct HomeView: View {","    @Environment(TWSManager.self) var manager","    var body: some View {","        ZStack {","            if let snippet = manager.snippets().first(where: { 