rn how to customize your view to fit your applications profile.","type":"text"},{"text":" ","type":"text"},{"text":"Customize loading, preloading and error views.","type":"text"}]},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Connect-with-the-TWS-portal":{"title":"Connect with the TWS portal","url":"\/tutorials\/tws\/remotesnippet#Connect-with-the-TWS-portal","type":"section","abstract":[{"type":"text","text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views."}],"kind":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal","role":"pseudoSymbol"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor#Custom-interceptors":{"role":"pseudoSymbol","abstract":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"title":"Custom interceptors","type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors","url":"\/tutorials\/tws\/custominterceptor#Custom-interceptors","kind":"section"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Display-your-first-snippet":{"url":"\/tutorials\/tutorial-table-of-contents\/display-your-first-snippet","kind":"article","role":"article","abstract":[],"title":"Display your first snippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet":{"title":"Display your first local snippet","estimatedTime":"2min","kind":"project","abstract":[{"type":"text","text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet","role":"project","type":"topic","url":"\/tutorials\/tws\/localsnippet"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation#Manager-creation-and-registration":{"title":"Manager creation and registration","type":"section","role":"pseudoSymbol","url":"\/tutorials\/tws\/managercreation#Manager-creation-and-registration","abstract":[{"text":"Learn different ways of creating and managing TWSManager","type":"text"}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration","kind":"section"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch#Mix-Match":{"url":"\/tutorials\/tws\/mixandmatch#Mix-Match","kind":"section","abstract":[{"type":"text","text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices."}],"role":"pseudoSymbol","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch#Mix-Match","title":"Mix & Match","type":"section"},"doc://tws-ios.TWS/tutorials/TWS/Notifications":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","url":"\/tutorials\/tws\/notifications","role":"project","title":"Integrating TWSNotifications with your notifications","estimatedTime":"3min","abstract":[{"text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base.","type":"text"}],"type":"topic","kind":"project"},"ManagerCreation_02.swift":{"highlights":[{"line":5},{"line":8}],"fileName":"ContentView.swift","syntax":"swift","type":"file","fileType":"swift","identifier":"ManagerCreation_02.swift","content":["import SwiftUI","import TWS","","struct ContentView: View {","    @State var manager = TWSFactory.new(with: TWSBasicConfiguration(id: \"projectId\"))","    var body: some View {","        HomeView()","            .twsRegister(using: manager)","    }","}","","struct HomeView: View {","    @Environment(TWSManager.self) var manager","    var body: some View {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }","        }","    }","}"]},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews":{"title":"Customize views to fit your application","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews","kind":"project","url":"\/tutorials\/tws\/customizingviews","abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}],"estimatedTime":"3min","role":"project","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet#Displaying-a-Snippet":{"title":"Displaying a Snippet","type":"section","role":"pseudoSymbol","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet","url":"\/tutorials\/tws\/localsnippet#Displaying-a-Snippet","kind":"section","abstract":[{"type":"text","text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content."}]},"ManagerCreation_00.swift":{"type":"file","syntax":"swift","fileName":"ContentView.swift","content":["import SwiftUI","import TWS","","struct ContentView: View {","    \/\/ Create snippet with TWSFactory","    @State var manager = TWSFactory.new(with: TWSBasicConfiguration(id: \"projectId\"))","    ","    var body: some {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }