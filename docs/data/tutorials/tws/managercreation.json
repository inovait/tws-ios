{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/tws\/managercreation"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"category":"Learn to use the SDK","title":"Creating and managing TWSManager","categoryPathComponent":"Tutorial-Table-of-Contents","role":"project"},"hierarchy":{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","modules":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet","projects":[{"sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet","kind":"task"}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet"},{"sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal","kind":"task"},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Presenting-snippets","kind":"task"}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet"},{"sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration","kind":"task"}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation"},{"sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch#Mix-Match","kind":"task"}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch"},{"sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications#Integrating-TWSNotifications","kind":"task"}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications"}]},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView","projects":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews","sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews#Custom-loading-and-error-views","kind":"task"}]},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor","sections":[{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors"}]}]}],"paths":[["doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/$volume","doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet"]]},"kind":"project","sections":[{"kind":"hero","estimatedTimeInMinutes":5,"content":[{"inlineContent":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"type":"paragraph"}],"title":"Creating and managing TWSManager","chapter":"Display your first snippet"},{"kind":"tasks","tasks":[{"title":"Manager creation and registration","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"text":"In this section you will learn different approaches for creation, registration with remote services and persistance of the TWSManager.","type":"text"}],"type":"paragraph"}]}],"stepsSection":[{"caption":[{"content":[{"type":"paragraph","inlineContent":[{"text":"If the instance was created for the first time, you have to register it with remote services to use it. Call registerManager() on the manager instance.","type":"text"}]}],"type":"aside","style":"note","name":"Note"}],"runtimePreview":null,"code":"ManagerCreation_00.swift","type":"step","content":[{"inlineContent":[{"text":"First way to create a TWSManager is by using TWSFactory.new(with:).","type":"text"},{"text":" ","type":"text"},{"text":"You provide the factory with your project id and the factory creates or retrieves(if instance for the configuration is already alive) a TWSManager instance for the provided configuration.","type":"text"}],"type":"paragraph"}],"media":null},{"caption":[{"inlineContent":[{"type":"text","text":"Use @Environment(TWSManager.self) to retrieve manager in ancestor views."}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"This way the manager will persist automatically as long as that view hierarchy is alive.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"}],"runtimePreview":null,"code":"ManagerCreation_01.swift","type":"step","content":[{"inlineContent":[{"type":"text","text":"Another way to create a manager is by using View extension function twsRegister(configuration:), which creates a TWSManager instance with the provided configuration, injects it into the view hiearchy and registers it with remote services."}],"type":"paragraph"}],"media":null},{"caption":[],"runtimePreview":null,"code":"ManagerCreation_02.swift","type":"step","content":[{"inlineContent":[{"text":"Last way to do it is using combination of both. You can create an instance using TWSFactory.new(with:) and then register and inject it into the environment using View extension function twsRegister(using:)","type":"text"}],"type":"paragraph"}],"media":null}],"anchor":"Manager-creation-and-registration"}]},{"kind":"callToAction","abstract":[{"type":"text","text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices."}],"title":"Combine remote and local snippets","featuredEyebrow":"Tutorial","action":{"type":"reference","isActive":true,"overridingTitle":"Get started","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch","overridingTitleInlineContent":[{"text":"Get started","type":"text"}]}}],"references":{"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents":{"url":"\/tutorials\/tutorial-table-of-contents","role":"overview","kind":"overview","abstract":[{"type":"text","text":"Follow the tutorials to learn how to use the SDK for displaying snippets."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","type":"topic","title":"Getting Started"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor","role":"project","title":"Intercepting URL requests","type":"topic","kind":"project","abstract":[{"text":"Learn how to intercept desired URLs and use them in native flows","type":"text"}],"url":"\/tutorials\/tws\/custominterceptor","estimatedTime":"5min"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation#Manager-creation-and-registration":{"title":"Manager creation and registration","kind":"section","url":"\/tutorials\/tws\/managercreation#Manager-creation-and-registration","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"type":"section","role":"pseudoSymbol","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration"},"doc://tws-ios.TWS/tutorials/TWS/Notifications":{"url":"\/tutorials\/tws\/notifications","title":"Integrating TWSNotifications with your notifications","abstract":[{"text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base.","type":"text"}],"estimatedTime":"3min","type":"topic","kind":"project","role":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch":{"role":"project","kind":"project","estimatedTime":"5min","type":"topic","title":"Combine remote and local snippets","url":"\/tutorials\/tws\/mixandmatch","abstract":[{"text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices.","type":"text"}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Display-your-first-snippet":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet","url":"\/tutorials\/tutorial-table-of-contents\/display-your-first-snippet","role":"article","title":"Display your first snippet","type":"topic","abstract":[],"kind":"article"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Connect-with-the-TWS-portal":{"url":"\/tutorials\/tws\/remotesnippet#Connect-with-the-TWS-portal","kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal","type":"section","title":"Connect with the TWS portal","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}]},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor#Custom-interceptors":{"abstract":[{"text":"Learn how to intercept desired URLs and use them in native flows","type":"text"}],"role":"pseudoSymbol","kind":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors","title":"Custom interceptors","type":"section","url":"\/tutorials\/tws\/custominterceptor#Custom-interceptors"},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews","title":"Customize views to fit your application","url":"\/tutorials\/tws\/customizingviews","estimatedTime":"3min","kind":"project","type":"topic","role":"project","abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}]},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet#Displaying-a-Snippet":{"type":"section","kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet","abstract":[{"type":"text","text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content."}],"title":"Displaying a Snippet","url":"\/tutorials\/tws\/localsnippet#Displaying-a-Snippet"},"ManagerCreation_01.swift":{"highlights":[{"line":5},{"line":6},{"line":7},{"line":8},{"line":9},{"line":10},{"line":11},{"line":12},{"line":13}],"identifier":"ManagerCreation_01.swift","fileType":"swift","syntax":"swift","fileName":"ContentView.swift","content":["import SwiftUI","import TWS","","struct ContentView: View {","    var body: some View {","        HomeView()","            .twsRegister(configuration: TWSBasicConfiguration(id: \"projectId\"))","    }","}","","struct HomeView: View {","    @Environment(TWSManager.self) var manager","    var body: some View {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }","        }","    }","}"],"type":"file"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch#Mix-Match":{"kind":"section","title":"Mix & Match","role":"pseudoSymbol","url":"\/tutorials\/tws\/mixandmatch#Mix-Match","abstract":[{"text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices.","type":"text"}],"type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch#Mix-Match"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet":{"estimatedTime":"3min","url":"\/tutorials\/tws\/remotesnippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"role":"project","kind":"project","title":"Display your first remote snippet","type":"topic"},"ManagerCreation_00.swift":{"fileName":"ContentView.swift","identifier":"ManagerCreation_00.swift","syntax":"swift","highlights":[],"type":"file","fileType":"swift","content":["import SwiftUI","import TWS","","struct ContentView: View {","    \/\/ Create snippet with TWSFactory","    @State var manager = TWSFactory.new(with: TWSBasicConfiguration(id: \"projectId\"))","    ","    var body: some {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }","        }.onAppear {","            \/\/ Register manager with remote services","            manager.registerManager()","        }","    }","}"]},"ManagerCreation_02.swift":{"fileName":"ContentView.swift","identifier":"ManagerCreation_02.swift","syntax":"swift","highlights":[{"line":5},{"line":8}],"type":"file","fileType":"swift","content":["import SwiftUI","import TWS","","struct ContentView: View {","    @State var manager = TWSFactory.new(with: TWSBasicConfiguration(id: \"projectId\"))","    var body: some View {","        HomeView()","            .twsRegister(using: manager)","    }","}","","struct HomeView: View {","    @Environment(TWSManager.self) var manager","    var body: some View {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }","        }","    }","}"]},"doc://tws-ios.TWS/tutorials/TWS/Notifications#Integrating-TWSNotifications":{"kind":"section","role":"pseudoSymb