{"hierarchy":{"modules":[{"projects":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet","sections":[{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet"}]},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet","sections":[{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal"},{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Presenting-snippets"}]},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration","kind":"task"}]},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch","sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch#Mix-Match","kind":"task"}]},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications#Integrating-TWSNotifications","kind":"task"}]}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet"},{"projects":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews","sections":[{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews#Custom-loading-and-error-views"}]},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor","sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors","kind":"task"}]}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView"}],"paths":[["doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/$volume","doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet"]],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents"},"variants":[{"paths":["\/tutorials\/tws\/managercreation"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation"},"kind":"project","metadata":{"role":"project","title":"Creating and managing TWSManager","categoryPathComponent":"Tutorial-Table-of-Contents","category":"Learn to use the SDK"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[{"title":"Creating and managing TWSManager","estimatedTimeInMinutes":5,"chapter":"Display your first snippet","kind":"hero","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}]}]},{"tasks":[{"anchor":"Manager-creation-and-registration","title":"Manager creation and registration","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"In this section you will learn different approaches for creation, registration with remote services and persistance of the TWSManager."}],"type":"paragraph"}]}],"stepsSection":[{"code":"ManagerCreation_00.swift","runtimePreview":null,"type":"step","content":[{"inlineContent":[{"text":"First way to create a TWSManager is by using TWSFactory.new(with:).","type":"text"},{"text":" ","type":"text"},{"text":"You provide the factory with your project id and the factory creates or retrieves(if instance for the configuration is already alive) a TWSManager instance for the provided configuration.","type":"text"}],"type":"paragraph"}],"media":null,"caption":[{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If the instance was created for the first time, you have to register it with remote services to use it. Call registerManager() on the manager instance."}]}]}]},{"code":"ManagerCreation_01.swift","runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Another way to create a manager is by using View extension function twsRegister(configuration:), which creates a TWSManager instance with the provided configuration, injects it into the view hiearchy and registers it with remote services.","type":"text"}]}],"media":null,"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use @Environment(TWSManager.self) to retrieve manager in ancestor views."}]},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"text":"This way the manager will persist automatically as long as that view hierarchy is alive.","type":"text"}],"type":"paragraph"}]}]},{"code":"ManagerCreation_02.swift","runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Last way to do it is using combination of both. You can create an instance using TWSFactory.new(with:) and then register and inject it into the environment using View extension function twsRegister(using:)"}]}],"media":null,"caption":[]}]}],"kind":"tasks"},{"title":"Combine remote and local snippets","action":{"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"type":"reference","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch","isActive":true,"overridingTitle":"Get started"},"abstract":[{"type":"text","text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices."}],"featuredEyebrow":"Tutorial","kind":"callToAction"}],"references":{"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Display-your-first-snippet":{"title":"Display your first snippet","url":"\/tutorials\/tutorial-table-of-contents\/display-your-first-snippet","type":"topic","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet","kind":"article","role":"article","abstract":[]},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews":{"kind":"project","url":"\/tutorials\/tws\/customizingviews","title":"Customize views to fit your application","estimatedTime":"3min","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews","abstract":[{"text":"Learn how to customize your view to fit your applications profile.","type":"text"},{"text":" ","type":"text"},{"text":"Customize loading, preloading and error views.","type":"text"}],"type":"topic","role":"project"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor","abstract":[{"text":"Learn how to intercept desired URLs and use them in native flows","type":"text"}],"estimatedTime":"5min","type":"topic","role":"project","kind":"project","title":"Intercepting URL requests","url":"\/tutorials\/tws\/custominterceptor"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","url":"\/tutorials\/tutorial-table-of-contents","type":"topic","abstract":[{"type":"text","text":"Follow the tutorials to learn how to use the SDK for displaying snippets."}],"kind":"overview","title":"Getting Started","role":"overview"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Connect-with-the-TWS-portal":{"abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"title":"Connect with the TWS portal","type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal","kind":"section","url":"\/tutorials\/tws\/remotesnippet#Connect-with-the-TWS-portal","role":"pseudoSymbol"},"doc://tws-ios.TWS/tutorials/TWS/Notifications#Integrating-TWSNotifications":{"kind":"section","title":"Integrating TWSNotifications","url":"\/tutorials\/tws\/notifications#Integrating-TWSNotifications","role":"pseudoSymbol","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications#Integrating-TWSNotifications","type":"section","abstract":[{"text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base.","type":"text"}]},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews#Custom-loading-and-error-views":{"title":"Custom loading and error views","type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews#Custom-loading-and-error-views","abstract":[{"text":"Learn how to customize your view to fit your applications profile.","type":"text"},{"text":" ","type":"text"},{"text":"Customize loading, preloading and error views.","type":"text"}],"url":"\/tutorials\/tws\/customizingviews#Custom-loading-and-error-views","kind":"section","role":"pseudoSymbol"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch#Mix-Match":{"kind":"section","url":"\/tutorials\/tws\/mixandmatch#Mix-Match","title":"Mix & Match","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch#Mix-Match","abstract":[{"type":"text","text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices."}],"type":"section","role":"pseudoSymbol"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor#Custom-interceptors":{"abstract":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"type":"section","kind":"section","title":"Custom interceptors","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors","role":"pseudoSymbol","url":"\/tutorials\/tws\/custominterceptor#Custom-interceptors"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet#Displaying-a-Snippet":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet","kind":"section","type":"section","abstract":[{"text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content.","type":"text"}],"url":"\/tutorials\/tws\/localsnippet#Displaying-a-Snippet","title":"Displaying a Snippet","role":"pseudoSymbol"},"ManagerCreation_00.swift":{"identifier":"ManagerCreation_00.swift","highlights":[],"fileType":"swift","type":"file","syntax":"swift","content":["import SwiftUI","import TWS","","struct ContentView: View {","    \/\/ Create snippet with TWSFactory","    @State var manager = TWSFactory.new(with: TWSBasicConfiguration(id: \"projectId\"))","    ","    var body: some {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }","        }.onAppear {","            \/\/ Register manager with remote services","            manager.registerManager()","        }","    }","}"],"fileName":"ContentView.swift"},"ManagerCreation_02.swift":{"fileName":"ContentView.swift","content":["import SwiftUI","import TWS","","struct ContentView: View {","    @State var manager = TWSFactory.new(with: TWSBasicConfiguration(id: \"projectId\"))","    var body: some View {","        HomeView()","            .twsRegister(using: manager)","    }","}","","struct HomeView: View {","    @Environment(TWSManager.self) var manager","    var body: some View {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }","        }","    }","}"],"syntax":"swift","identifier":"ManagerCreation_02.swift","type":"file","fileType":"swift","highlights":[{"line":5},{"line":8}]},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation":{"estimatedTime":"5min","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","type":"topic","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"url":"\/tutorials\/tws\/managercreation","kind":"project","title":"Creating and managing TWSManager","role":"project"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet":{"abstract":[{"type":"text","text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content."}],"estimatedTime":"2min","kind":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet","type":"topic","title":"Display your first local snippet","url":"\/tutorials\/tws\/localsnippet","role":"project"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Customizing-TWSView":{"title":"Customizing TWSView","role":"article","kind":"article","type":"topic","abstract":[],"url":"\/tutorials\/tutorial-table-of-contents\/customizing-twsview","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch":{"role":"project","kind":"project","estimatedTime":"5min","url":"\/tutorials\/tws\/mixandmatch","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch","type":"topic","title":"Combine remote and local snippets","abstract":[{"text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices.","type":"text"}]},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet":{"type":"topic","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet","title":"Display your first remote snippet","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"kind":"project","url":"\/tutorials\/tws\/remotesnippet","role":"project","estimatedTime":"3min"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation#Manager-creation-and-registration":{"title":"Manager creation and registration","url":"\/tutorials\/tws\/managercreation#Manager-creation-and-registration","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration","type":"section","kind":"section","role":"pseudoSymbol","abstract":[{"text":"Learn different ways of creating and managing TWSManager","type":"text"}]},"doc://tws-ios.TWS/tutorials/TWS/Notifications":{"role":"project","type":"topic","url":"\/tutorials\/tws\/notifications","abstract":[{"type":"text","text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base."}],"kind":"project","estimatedTime":"3min","title":"Integrating TWSNotifications with your notifications","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications"},"ManagerCreation_01.swift":{"content":["import SwiftUI","import TWS","","struct ContentView: View {","    var body: some View {","        HomeView()","            .twsRegister(configuration: TWSBasicConfiguration(id: \"projectId\"))","    }","}","","struct HomeView: View {","    @Environment(TWSManager.self) var manager","    var body: some View {","        ZStack {","            if let snippet = manager.snippets().first(where: { $0.id == \"snippetId\" }) {","                TWSView(snippet: snippet)","            }","        }","    }","}"],"identifier":"ManagerCreation_01.swift","fileName":"ContentView.swift","type":"file","syntax":"swift","fileType":"swift","highlights":[{"line":5},{"line":6},{"line":7},{"line":8},{"line":9},{"line":10},{"line":11},{"line":12},{"line":13}]},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Presenting-snippets":{"kind":"section","role":"pseudoSymbol","abstract":[{"type":"text","text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views."}],"type":"section","title":"Presenting snippets","url":"\/tutorials\/tws\/remotesnippet#Presenting-snippets","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Presenting-snippets"}}}