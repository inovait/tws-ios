{"metadata":{"title":"Intercepting URL requests","category":"Learn to use the SDK","categoryPathComponent":"Tutorial-Table-of-Contents","role":"project"},"hierarchy":{"paths":[["doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/$volume","doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView"]],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","modules":[{"projects":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet","sections":[{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet"}]},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet","sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal","kind":"task"},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Presenting-snippets","kind":"task"}]},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","sections":[{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration"}]},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch","sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch#Mix-Match","kind":"task"}]},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","sections":[{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications#Integrating-TWSNotifications"}]}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet"},{"projects":[{"sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews#Custom-loading-and-error-views","kind":"task"}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews"},{"sections":[{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors"}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor"}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[{"estimatedTimeInMinutes":5,"content":[{"inlineContent":[{"text":"Learn how to intercept desired URLs and use them in native flows","type":"text"}],"type":"paragraph"}],"title":"Intercepting URL requests","kind":"hero","chapter":"Customizing TWSView"},{"tasks":[{"title":"Custom interceptors","anchor":"Custom-interceptors","contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"TWSView has an ability to catch URL requests before they are loaded into the view. This gives you the capability to catch that URL and trigger a native flow."}],"type":"paragraph"}],"kind":"contentAndMedia","mediaPosition":"trailing"}],"stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Lets take code from previous tutorial as base.","type":"text"}]}],"runtimePreview":null,"media":null,"type":"step","code":"CustomInterceptor_00.swift","caption":[]},{"content":[{"type":"paragraph","inlineContent":[{"text":"To use a custom interceptor we need to implement a class that conforms TWSViewInterceptor protocol.","type":"text"}]}],"runtimePreview":null,"media":null,"type":"step","code":"CustomInterceptor_01.swift","caption":[]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Imagine that https:\/\/www.myWebPage.com has two paths for which we want to implement a native screen instead of displaying them in TWSView."}]}],"runtimePreview":null,"media":null,"type":"step","code":"CustomInterceptor_02.swift","caption":[{"type":"paragraph","inlineContent":[{"text":"Those paths are \/helloWorld which displays hello World text and \/greetUser\/{username} which displays a greeting for a user.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a representation of the current destination to the implementation."},{"type":"text","text":" "},{"type":"text","text":"Create an instance of your interceptor and bind it to TWSView."}]}],"runtimePreview":null,"media":null,"type":"step","code":"CustomInterceptor_03.swift","caption":[]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now we add views for corresponding destinations and we are done."}]}],"runtimePreview":null,"media":null,"type":"step","code":"CustomInterceptor_04.swift","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Every time TWSView tries to load"},{"type":"text","text":" "},{"code":"https:\/\/www.myWebPage.com\/helloWorld","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"https:\/\/www.myWebPage.com\/greetUser\/{userName}","type":"codeVoice"},{"type":"text","text":""},{"type":"text","text":" "},{"type":"text","text":"our custom flow will be triggered."}]}]}]}],"kind":"tasks"}],"identifier":{"url":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor","interfaceLanguage":"swift"},"variants":[{"paths":["\/tutorials\/tws\/custominterceptor"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"project","references":{"doc://tws-ios.TWS/tutorials/TWS/Notifications":{"kind":"project","title":"Integrating TWSNotifications with your notifications","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","abstract":[{"text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base.","type":"text"}],"url":"\/tutorials\/tws\/notifications","type":"topic","estimatedTime":"3min","role":"project"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet":{"url":"\/tutorials\/tws\/localsnippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet","role":"project","estimatedTime":"2min","title":"Display your first local snippet","type":"topic","abstract":[{"text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content.","type":"text"}],"kind":"project"},"CustomInterceptor_03.swift":{"fileName":"CustomView.swift","syntax":"swift","content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    @State var navigationInterceptor = NavigationInterceptor()","    ","    var body : some View {","        ZStack {","            TWSView(snippet: mySnippet)","                .twsBind(loadingView: { AnyView(LoadingView()) })","                .twsBind(preloadingView: { AnyView(LoadingView()) })","                .twsBind(errorView: { error in AnyView(ErrorView(error: error))})","                .twsBind(interceptor: NavigationInterceptor)","        }","    }","}","","class NavigationInterceptor: TWSViewInterceptor {","    var destination: Destination?","    ","    func handleUrl(_ url: URL) -> Bool {","        if url.absoluteString == \"https:\/\/www.myWebPage.com\/helloWorld\" {","            destination = .helloWorld","            return true","        } else if url.absoluteString.contains(\"https:\/\/www.myWebPage.com\/greetUser\/\") {","            destination = .greetUser(url.lastPathComponent)","            return true","        }","        return false","    }","}","","enum Destination {","    case helloWorld","    case greetUser(String)","}"],"type":"file","identifier":"CustomInterceptor_03.swift","highlights":[{"line":7},{"line":15},{"line":21},{"line":22},{"line":25},{"line":28},{"line":34},{"line":35},{"line":36},{"line":37},{"line":38}],"fileType":"swift"},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews#Custom-loading-and-error-views":{"url":"\/tutorials\/tws\/customizingviews#Custom-loading-and-error-views","kind":"section","title":"Custom loading and error views","role":"pseudoSymbol","type":"section","abstract":[{"text":"Learn how to customize your view to fit your applications profile.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews#Custom-loading-and-error-views"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Connect-with-the-TWS-portal":{"role":"pseudoSymbol","title":"Connect with the TWS portal","type":"section","kind":"section","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"url":"\/tutorials\/tws\/remotesnippet#Connect-with-the-TWS-portal","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet#Displaying-a-Snippet":{"title":"Displaying a Snippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet","type":"section","kind":"section","abstract":[{"type":"text","text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content."}],"role":"pseudoSymbol","url":"\/tutorials\/tws\/localsnippet#Displaying-a-Snippet"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Customizing-TWSView":{"role":"article","kind":"article","abstract":[],"url":"\/tutorials\/tutorial-table-of-contents\/customizing-twsview","title":"Customizing TWSView","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView","type":"topic"},"CustomInterceptor_01.swift":{"syntax":"swift","highlights":[{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22}],"fileType":"swift","fileName":"CustomView.swift","identifier":"CustomInterceptor_01.swift","content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    ","    var body : some View {","        ZStack {","            TWSView(snippet: mySnippet)","                .twsBind(loadingView: { AnyView(LoadingView()) })","                .twsBind(preloadingView: { AnyView(LoadingView()) })","                .twsBind(errorView: { error in AnyView(ErrorView(error: error))})","        }","    }","}","","class NavigationInterceptor: TWSViewInterceptor {","    func handleUrl(_ url: URL) -> Bool {","        ","    }","}"],"type":"file"},"CustomInterceptor_04.swift":{"type":"file","fileName":"CustomView.swift","content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    @State var navigationInterceptor = NavigationInterceptor()","    ","    var body : some View {","        ZStack {","            TWSView(snippet: mySnippet)","                .twsBind(loadingView: { AnyView(LoadingView()) })","                .twsBind(preloadingView: { AnyView(LoadingView()) })","                .twsBind(errorView: { error in AnyView(ErrorView(error: error))})","                .twsBind(interceptor: NavigationInterceptor)","            switch navigationInterceptor.destination {","            case .helloWorld:","                Text(\"Hello World!\")","                    .frame(maxWidth: .infinity, maxHeight: .infinity)","                    .background(.white)","            case .greetUser(let username):","                Text(\"Hello, \\(username)!\")","                    .frame(maxWidth: .infinity, maxHeight: .infinity)","                    .background(.white)","            case .none:","                EmptyView()","            }","        }","    }","}","","class NavigationInterceptor: TWSViewInterceptor {","    var destination: Destination?","    ","    func handleUrl(_ url: URL) -> Bool {","        if url.absoluteString == \"https:\/\/www.myWebPage.com\/helloWorld\" {","            destination = .helloWorld","            return true","        } else if url.absoluteString.contains(\"https:\/\/www.myWebPage.com\/greetUser\/\") {","            destination = .greetUser(url.lastPathComponent)","            return true","        }","        return false","    }","}","","enum Destination {","    case helloWorld","    case greetUser(String)","}"],"highlights":[{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27}],"fileType":"swift","identifier":"CustomInterceptor_04.swift","syntax":"swift"},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews":{"kind":"project","role":"project","type":"topic","estimatedTime":"3min","abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}],"title":"Customize views to fit your application","url":"\/tutorials\/tws\/customizingviews","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor#Custom-interceptors":{"kind":"section","abstract":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"type":"section","title":"Custom interceptors","role":"pseudoSymbol","url":"\/tutorials\/tws\/custominterceptor#Custom-interceptors","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch#Mix-Match":{"kind":"section","abstract":[{"text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices.","type":"text"}],"type":"section","title":"Mix & Match","role":"pseudoSymbol","url":"\/tutorials\/tws\/mixandmatch#Mix-Match","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch#Mix-Match"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Presenting-snippets":{"url":"\/tutorials\/tws\/remotesnippet#Presenting-snippets","kind":"section","title":"Presenting snippets","type":"section","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"role":"pseudoSymbol","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Presenting-snippets"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Display-your-first-snippet":{"kind":"article","abstract":[],"type":"topic","title":"Display your first snippet","role":"article","url":"\/tutorials\/tutorial-table-of-contents\/display-your-first-snippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation":{"url":"\/tutorials\/tws\/managercreation","type":"topic","estimatedTime":"5min","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"role":"project","kind":"project","title":"Creating and managing TWSManager","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch":{"abstract":[{"type":"text","text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices."}],"url":"\/tutorials\/tws\/mixandmatch","type":"topic","title":"Combine remote and local snippets","role":"project","kind":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch","estimatedTime":"5min"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor":{"type":"topic","abstract":[{"text":"Learn how to intercept desired URLs and use them in native flows","type":"text"}],"kind":"project","title":"Intercepting URL requests","url":"\/tutorials\/tws\/custominterceptor","estimatedTime":"5min","role":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation#Manager-creation-and-registration":{"abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"kind":"section","url":"\/tutorials\/tws\/managercreation#Manager-creation-and-registration","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration","type":"section","title":"Manager creation and registration","role":"pseudoSymbol"},"CustomInterceptor_00.swift":{"identifier":"CustomInterceptor_00.swift","fileName":"CustomView.swift","fileType":"swift","syntax":"swift","highlights":[],"content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    ","    var body : some View {","        ZStack {","            TWSView(snippet: mySnippet)","                .twsBind(loadingView: { AnyView(LoadingView()) })","                .twsBind(preloadingView: { AnyView(LoadingView()) })","                .twsBind(errorView: { error in AnyView(ErrorView(error: error))})","        }","    }","}"],"type":"file"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet":{"kind":"project","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as