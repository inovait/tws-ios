{"kind":"project","schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"role":"project","categoryPathComponent":"Tutorial-Table-of-Contents","title":"Intercepting URL requests","category":"Learn to use the SDK"},"identifier":{"url":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor","interfaceLanguage":"swift"},"hierarchy":{"modules":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet"}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet"},{"sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal","kind":"task"},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Presenting-snippets","kind":"task"}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet"},{"sections":[{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration"}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation"},{"sections":[{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch#Mix-Match"}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch"},{"sections":[{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications#Integrating-TWSNotifications"}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications"}]},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView","projects":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews","sections":[{"kind":"task","reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews#Custom-loading-and-error-views"}]},{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor","sections":[{"reference":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors","kind":"task"}]}]}],"reference":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","paths":[["doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/$volume","doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView"]]},"sections":[{"chapter":"Customizing TWSView","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}]}],"estimatedTimeInMinutes":5,"title":"Intercepting URL requests","kind":"hero"},{"kind":"tasks","tasks":[{"anchor":"Custom-interceptors","title":"Custom interceptors","stepsSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Lets take code from previous tutorial as base."}]}],"media":null,"code":"CustomInterceptor_00.swift","caption":[],"type":"step","runtimePreview":null},{"type":"step","content":[{"inlineContent":[{"text":"To use a custom interceptor we need to implement a class that conforms TWSViewInterceptor protocol.","type":"text"}],"type":"paragraph"}],"caption":[],"code":"CustomInterceptor_01.swift","runtimePreview":null,"media":null},{"content":[{"type":"paragraph","inlineContent":[{"text":"Imagine that https:\/\/www.myWebPage.com has two paths for which we want to implement a native screen instead of displaying them in TWSView.","type":"text"}]}],"media":null,"runtimePreview":null,"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Those paths are \/helloWorld which displays hello World text and \/greetUser\/{username} which displays a greeting for a user."}]},{"name":"Note","type":"aside","content":[{"inlineContent":[{"text":"TWSIntercepted supports two types url and path. Url branch is triggered when the page is loaded into webView, those are typically MPA web pages.","type":"text"},{"text":" ","type":"text"},{"text":"Meanwhile path branch is triggered on SPA pages, because there are no full loads when navigating SPA web page.","type":"text"}],"type":"paragraph"}],"style":"note"}],"code":"CustomInterceptor_02.swift"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Add a representation of the current destination to the implementation.","type":"text"},{"text":" ","type":"text"},{"text":"Create an instance of your interceptor and bind it to TWSView.","type":"text"}]}],"media":null,"runtimePreview":null,"type":"step","caption":[],"code":"CustomInterceptor_03.swift"},{"content":[{"inlineContent":[{"type":"text","text":"Now we add views for corresponding destinations and we are done."}],"type":"paragraph"}],"media":null,"runtimePreview":null,"type":"step","caption":[{"inlineContent":[{"text":"Every time TWSView tries to load","type":"text"},{"text":" ","type":"text"},{"code":"https:\/\/www.myWebPage.com\/helloWorld","type":"codeVoice"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"code":"https:\/\/www.myWebPage.com\/greetUser\/{userName}","type":"codeVoice"},{"text":"","type":"text"},{"text":" ","type":"text"},{"text":"our custom flow will be triggered.","type":"text"}],"type":"paragraph"}],"code":"CustomInterceptor_04.swift"}],"contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"text":"TWSView has an ability to catch URL requests before they are loaded into the view. This gives you the capability to catch that URL and trigger a native flow.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing"}]}]}],"variants":[{"paths":["\/tutorials\/tws\/custominterceptor"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://tws-ios.TWS/tutorials/TWS/Notifications":{"url":"\/tutorials\/tws\/notifications","title":"Integrating TWSNotifications with your notifications","abstract":[{"type":"text","text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base."}],"role":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","estimatedTime":"3min","kind":"project","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch":{"title":"Combine remote and local snippets","abstract":[{"text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices.","type":"text"}],"kind":"project","type":"topic","url":"\/tutorials\/tws\/mixandmatch","role":"project","estimatedTime":"5min","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch"},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews#Custom-loading-and-error-views":{"title":"Custom loading and error views","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews#Custom-loading-and-error-views","type":"section","url":"\/tutorials\/tws\/customizingviews#Custom-loading-and-error-views","abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"text":"Customize loading, preloading and error views.","type":"text"}],"kind":"section","role":"pseudoSymbol"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Customizing-TWSView":{"type":"topic","abstract":[],"title":"Customizing TWSView","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView","role":"article","kind":"article","url":"\/tutorials\/tutorial-table-of-contents\/customizing-twsview"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation#Manager-creation-and-registration":{"title":"Manager creation and registration","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration","kind":"section","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"role":"pseudoSymbol","type":"section","url":"\/tutorials\/tws\/managercreation#Manager-creation-and-registration"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor#Custom-interceptors":{"url":"\/tutorials\/tws\/custominterceptor#Custom-interceptors","kind":"section","title":"Custom interceptors","abstract":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors","type":"section","role":"pseudoSymbol"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Connect-with-the-TWS-portal":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal","url":"\/tutorials\/tws\/remotesnippet#Connect-with-the-TWS-portal","kind":"section","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"type":"section","title":"Connect with the TWS portal","role":"pseudoSymbol"},"CustomInterceptor_00.swift":{"type":"file","syntax":"swift","fileName":"CustomView.swift","fileType":"swift","highlights":[],"content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    ","    var body : some View {","        ZStack {","            TWSView(snippet: mySnippet)","                .twsBind(loadingView: { AnyView(LoadingView()) })","                .twsBind(preloadingView: { AnyView(LoadingView()) })","                .twsBind(errorView: { error in AnyView(ErrorView(error: error))})","        }","    }","}"],"identifier":"CustomInterceptor_00.swift"},"doc://tws-ios.TWS/tutorials/TWS/Notifications#Integrating-TWSNotifications":{"title":"Integrating TWSNotifications","role":"pseudoSymbol","kind":"section","abstract":[{"type":"text","text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base."}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications#Integrating-TWSNotifications","url":"\/tutorials\/tws\/notifications#Integrating-TWSNotifications","type":"section"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor":{"abstract":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"url":"\/tutorials\/tws\/custominterceptor","kind":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor","type":"topic","role":"project","title":"Intercepting URL requests","estimatedTime":"5min"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet":{"title":"Display your first local snippet","abstract":[{"text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content.","type":"text"}],"estimatedTime":"2min","url":"\/tutorials\/tws\/localsnippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet","role":"project","type":"topic","kind":"project"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet":{"type":"topic","role":"project","kind":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet","title":"Display your first remote snippet","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"url":"\/tutorials\/tws\/remotesnippet","estimatedTime":"3min"},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews":{"estimatedTime":"3min","abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}],"role":"project","kind":"project","title":"Customize views to fit your application","url":"\/tut