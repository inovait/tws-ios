l-Table-of-Contents\/$volume","doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView"]]},"sections":[{"estimatedTimeInMinutes":5,"kind":"hero","content":[{"inlineContent":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"type":"paragraph"}],"title":"Intercepting URL requests","chapter":"Customizing TWSView"},{"kind":"tasks","tasks":[{"stepsSection":[{"media":null,"code":"CustomInterceptor_00.swift","type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Lets take code from previous tutorial as base.","type":"text"}]}],"runtimePreview":null},{"media":null,"code":"CustomInterceptor_01.swift","type":"step","caption":[],"content":[{"inlineContent":[{"text":"To use a custom interceptor we need to implement a class that conforms TWSViewInterceptor protocol.","type":"text"}],"type":"paragraph"}],"runtimePreview":null},{"media":null,"code":"CustomInterceptor_02.swift","type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Those paths are \/helloWorld which displays hello World text and \/greetUser\/{username} which displays a greeting for a user."}]}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Imagine that https:\/\/www.myWebPage.com has two paths for which we want to implement a native screen instead of displaying them in TWSView."}]}],"runtimePreview":null},{"media":null,"code":"CustomInterceptor_03.swift","type":"step","caption":[],"content":[{"inlineContent":[{"text":"Add a representation of the current destination to the implementation.","type":"text"},{"text":" ","type":"text"},{"text":"Create an instance of your interceptor and bind it to TWSView.","type":"text"}],"type":"paragraph"}],"runtimePreview":null},{"media":null,"code":"CustomInterceptor_04.swift","type":"step","caption":[{"inlineContent":[{"type":"text","text":"Every time TWSView tries to load"},{"type":"text","text":" "},{"type":"codeVoice","code":"https:\/\/www.myWebPage.com\/helloWorld"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"https:\/\/www.myWebPage.com\/greetUser\/{userName}"},{"type":"text","text":""},{"type":"text","text":" "},{"type":"text","text":"our custom flow will be triggered."}],"type":"paragraph"}],"content":[{"inlineContent":[{"text":"Now we add views for corresponding destinations and we are done.","type":"text"}],"type":"paragraph"}],"runtimePreview":null}],"anchor":"Custom-interceptors","title":"Custom interceptors","contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"text":"TWSView has an ability to catch URL requests before they are loaded into the view. This gives you the capability to catch that URL and trigger a native flow.","type":"text"}],"type":"paragraph"}],"mediaPosition":"trailing"}]}]}],"kind":"project","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor"},"metadata":{"categoryPathComponent":"Tutorial-Table-of-Contents","category":"Learn to use the SDK","title":"Intercepting URL requests","role":"project"},"references":{"doc://tws-ios.TWS/tutorials/TWS/Notifications":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","role":"project","url":"\/tutorials\/tws\/notifications","abstract":[{"type":"text","text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base."}],"title":"Integrating TWSNotifications with your notifications","kind":"project","estimatedTime":"3min","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet":{"title":"Display your first local snippet","role":"project","url":"\/tutorials\/tws\/localsnippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet","kind":"project","abstract":[{"type":"text","text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content."}],"estimatedTime":"2min","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch#Mix-Match":{"title":"Mix & Match","abstract":[{"type":"text","text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices."}],"role":"pseudoSymbol","url":"\/tutorials\/tws\/mixandmatch#Mix-Match","type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch#Mix-Match","kind":"section"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet":{"title":"Display your first remote snippet","role":"project","kind":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet","url":"\/tutorials\/tws\/remotesnippet","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"estimatedTime":"3min","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor":{"title":"Intercepting URL requests","role":"project","url":"\/tutorials\/tws\/custominterceptor","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor","kind":"project","abstract":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"estimatedTime":"5min","type":"topic"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Customizing-TWSView":{"role":"article","type":"topic","url":"\/tutorials\/tutorial-table-of-contents\/customizing-twsview","kind":"article","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Customizing-TWSView","abstract":[],"title":"Customizing TWSView"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor#Custom-interceptors":{"role":"pseudoSymbol","type":"section","url":"\/tutorials\/tws\/custominterceptor#Custom-interceptors","kind":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors","abstract":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"title":"Custom interceptors"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation#Manager-creation-and-registration":{"role":"pseudoSymbol","type":"section","url":"\/tutorials\/tws\/managercreation#Manager-creation-and-registration","kind":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation#Manager-creation-and-registration","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"title":"Manager creation and registration"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet#Displaying-a-Snippet":{"role":"pseudoSymbol","url":"\/tutorials\/tws\/localsnippet#Displaying-a-Snippet","type":"section","abstract":[{"text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content.","type":"text"}],"kind":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet","title":"Displaying a Snippet"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch","role":"project","url":"\/tutorials\/tws\/mixandmatch","abstract":[{"type":"text","text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices."}],"title":"Combine remote and local snippets","kind":"project","estimatedTime":"5min","type":"topic"},"CustomInterceptor_03.swift":{"fileName":"CustomView.swift","identifier":"CustomInterceptor_03.swift","type":"file","fileType":"swift","highlights":[{"line":7},{"line":15},{"line":21},{"line":22},{"line":25},{"line":28},{"line":34},{"line":35},{"line":36},{"line":37},{"line":38}],"syntax":"swift","content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    @State var navigationInterceptor = NavigationInterceptor()","    ","    var body : some View {","        ZStack {","            TWSView(snippet: mySnippet)","                .twsBind(loadingView: { AnyView(LoadingView()) })","                .twsBind(preloadingView: { AnyView(LoadingView()) })","                .twsBind(errorView: { error in AnyView(ErrorView(error: error))})","                .twsBind(interceptor: NavigationInterceptor)","        }","    }","}","","class NavigationInterceptor: TWSViewInterceptor {","    var destination: Destination?","    ","    func handleUrl(_ url: URL) -> Bool {","        if url.absoluteString == \"https:\/\/www.myWebPage.com\/helloWorld\" {","            destination = .helloWorld","            return true","        } else if url.absoluteString.contains(\"https:\/\/www.myWebPage.com\/greetUser\/\") {","            destination = .greetUser(url.lastPathComponent)","            return true","        }","        return false","    }","}","","enum Destination {","    case helloWorld","    case greetUser(String)","}"]},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation":{"title":"Creating and managing TWSManager","role":"project","url":"\/tutorials\/tws\/managercreation","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","kind":"project","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"estimatedTime":"5min","type":"topic"},"CustomInterceptor_01.swift":{"identifier":"CustomInterceptor_01.swift","highlights":[{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22}],"type":"file","syntax":"swift","fileName":"CustomView.swift","fileType":"swift","content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    ","    var body : some View {","        ZStack {","            TWSView(snippet: mySnippet)","                .twsBind(loadingView: { AnyView(LoadingView()) })","                .twsBind(preloadingView: { AnyView(LoadingView()) })","                .twsBind(errorView: { error in AnyView(ErrorView(error: error))})","        }","    }","}","","class NavigationInterceptor: TWSViewInterceptor {","    func handleUrl(_ url: URL) -> Bool {","        ","    }","}"]},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Display-your-first-snippet":{"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-first-snippet","url":"\/tutorials\/tutorial-table-of-contents\/display-your-first-snippet","title":"Display your first snippet","kind":"article","role":"article","abstract":[],"type":"topic"},"CustomInterceptor_02.swift":{"content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    ","    var body : some View {","        ZStack {","            TWSView(snippet: mySnippet)","                .twsBind(loadingView: { AnyView(LoadingView()) })","                .twsBind(preloadingView: { AnyView(LoadingView()) })","                .twsBind(errorView: { error in AnyView(ErrorView(error: error))})","        }","    }","}","","class NavigationInterceptor: TWSViewInterceptor {","    func handleUrl(_ url: URL) -> Bool {","        if url.absoluteString == \"https:\/\/www.myWebPage.com\/helloWorld\" {","            return true","        } else if url.absoluteString.contains(\"https:\/\/www.myWebPage.com\/greetUser\/\") {","            return true","        }","        return false","    }","}"],"highlights":[{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25}],"type":"file","fileName":"CustomView.swift","syntax":"swift","fileType":"swift","identifier":"CustomInterceptor_02.swift"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Presenting-snippets":{"title":"Presenting snippets","abstract":[{"type":"text","text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views."}],"role":"pseudoSymbol","url":"\/tutorials\/tws\/remotesnippet#Presenting-snippets","type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Presenting-snippets","kind":"section"},"CustomInterceptor_00.swift":{"type":"file","identifier":"CustomInterceptor_00.swift","fileName":"CustomView.swift","syntax":"swift","content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    ","    var body : some View {","        ZStack {","            TWSView(snippet: mySnippet)","                .twsBind(loadingView: { AnyView(LoadingView()) })","                .twsBind(preloadingView: { AnyView(LoadingView()) })","                .twsBind(errorView: { error in AnyView(ErrorView(error: error))})","        }","    }","}"],"fileType":"swift","highlights":[]},"CustomInterceptor_04.swift":{"identifier":"CustomInterceptor_04.swift","content":["import Foundation","import SwiftUI","import TWS","","struct CustomView: View {","    let mySnippet = TWSSnippet(id: \"mySnippet\", target: URL(string: \"https:\/\/www.myWebPage.com\")!)","    @State var navigationInterceptor = NavigationInterceptor()","    ","    var body : some View {","        ZStack {","            TWSView(snippet: mySnippet)","                .twsBind(loadingView: { AnyView(LoadingView()) })","                .twsBind(preloadingView: { AnyView(LoadingView()) })","                .twsBind(errorView: { error in AnyView(ErrorView(error: error))})","                .twsBind(interceptor: NavigationInterceptor)","            switch navigationInterceptor.destination {","            case .helloWorld:","                Text(\"Hello World!\")","                    .frame(maxWidth: .infinity, maxHeight: .infinity)","                    .background(.white)","            case .greetUser(let username):","                Text(\"Hello, \\(username)!\")","                    .frame(maxWidth: .infinity, maxHeight: .infinity)","                    .background(.white)","            case .none:","                EmptyView()","            }","        }","    }","}","","class NavigationInterceptor: TWSViewInterceptor {","    var destination: Destination?","    ","    func handleUrl(_ url: URL) -> Bool {","        if url.absoluteString == \"https:\/\/www.myWebPage.com\/helloWorld\" {","            destination = .helloWorld","            return true","        } else if url.absoluteString.contains(\"https:\/\/www.myWebPage.com\/greetUser\/\") {","            destination = .greetUser(url.lastPathComponent)","            return true","        }","        return false","    }","}","","enum Destination {","    case helloWorld","    case greetUser(String)","}"],"syntax":"swift","highlights":[{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25},{"line":26},{"line":27}],"fileName":"CustomView.swift","fileType":"swift","type":"file"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents":{"title":"Getting Started","role":"overview","url":"\/tutorials\/tutoria