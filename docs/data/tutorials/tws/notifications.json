.swift","type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"As noted in first step TWSManager needs to be alive when push notification is handled. This usually means that the instance should be created before registering @UIApplicationDelegate","type":"text"}]}],"media":null,"runtimePreview":null,"caption":[]}],"title":"Integrating TWSNotifications","anchor":"Integrating-TWSNotifications","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"This section teaches you how to structure and integrate TWSNotifications, to leverage push notifications even more.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"TWSNotifications is a mechanism that allows you to parse a notification content and display a full screen overlay of the corresponding snippet.","type":"text"}]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"This tutorial assumes you are already have working push notifications implementation.","type":"text"}]}],"name":"Note"}],"kind":"contentAndMedia","mediaPosition":"trailing"}]}],"kind":"tasks"},{"abstract":[{"text":"Learn how to customize your view to fit your applications profile.","type":"text"},{"text":" ","type":"text"},{"text":"Customize loading, preloading and error views.","type":"text"}],"action":{"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews","isActive":true,"overridingTitle":"Get started","type":"reference"},"featuredEyebrow":"Tutorial","kind":"callToAction","title":"Customize views to fit your application"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents/Display-your-first-snippet":{"title":"Display your first snippet","url":"\/tutorials\/tutorial-table-of-contents\/display-your-first-snippet","type":"topic","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents\/Display-your-fir