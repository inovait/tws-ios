cle","url":"\/tutorials\/tutorial-table-of-contents\/customizing-twsview","type":"topic","title":"Customizing TWSView"},"doc://tws-ios.TWS/tutorials/TWS/CustomizingViews":{"title":"Customize views to fit your application","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews","kind":"project","url":"\/tutorials\/tws\/customizingviews","abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}],"estimatedTime":"3min","role":"project","type":"topic"},"Notifications_01.swift":{"syntax":"swift","identifier":"Notifications_01.swift","fileType":"swift","type":"file","content":["import SwiftUI","import TWS","","struct App: App {","    @State var manager = TWSFactory.new(with: TWSBasicConfiguration(id: \"projectId\"))","    @UIApplicationDelegateAdaptor(ApplicationDelegate.self) var applicationDelegate","    ","    var body: some Scene {","        WindowGroup {","            ContentView()","                .twsRegister(using: manager)","        }","    }","}"],"fileName":"App.swift","highlights":[]},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Presenting-snippets":{"kind":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Presenting-snippets","url":"\/tutorials\/tws\/remotesnippet#Presenting-snippets","role":"pseudoSymbol","title":"Presenting snippets","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"type":"section"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet#Connect-with-the-TWS-portal":{"title":"Connect with the TWS portal","url":"\/tutorials\/tws\/remotesnippet#Connect-with-the-TWS-portal","type":"section","abstract":[{"type":"text","text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views."}],"kind":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet#Connect-with-the-TWS-portal","role":"pseudoSymbol"},"Notifications.json":{"syntax":"json","fileType":"json","identifier":"Notifications.json","type":"file","content":["{","  \"aps\": {","    \"alert\": {","      \"title\": \"New Offer!\",","      \"body\": \"Tap to see our latest deals.\"","    },","    \"badge\": 1,","    \"sound\": \"default\"","  },","  \"type\": \"snippet_push\",","  \"path\": \"projectId\/snippetId\"","}"],"fileName":"aps.json","highlights":[]},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch#Mix-Match":{"url":"\/tutorials\/tws\/mixandmatch#Mix-Match","kind":"section","abstract":[{"type":"text","text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices."}],"role":"pseudoSymbol","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch#Mix-Match","title":"Mix & Match","type":"section"},"doc://tws-ios.TWS/tutorials/TWS/CustomInterceptor#Custom-interceptors":{"role":"pseudoSymbol","abstract":[{"type":"text","text":"Learn how to intercept desired URLs and use them in native flows"}],"title":"Custom interceptors","type":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomInterceptor#Custom-interceptors","url":"\/tutorials\/tws\/custominterceptor#Custom-interceptors","kind":"section"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet#Displaying-a-Snippet":{"title":"Displaying a Snippet","type":"section","role":"pseudoSymbol","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet#Displaying-a-Snippet","url":"\/tutorials\/tws\/localsnippet#Displaying-a-Snippet","kind":"secti