e","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"projectId and snippetId should be replaced with actual ids, again this will work correctly if the TWSManager with the same projectId configuration already exists.","type":"text"}]}]}],"content":[{"inlineContent":[{"text":"Notification data should include two keys “type” and “path”. If they are not include handleTWSPushNotification(userInfo:) will ignore the notification.","type":"text"}],"type":"paragraph"}],"code":"Notifications.json","runtimePreview":null,"media":null,"type":"step"},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"As noted in first step TWSManager needs to be alive when push notification is handled. This usually means that the instance should be created before registering @UIApplicationDelegate","type":"text"}]}],"code":"Notifications_01.swift","runtimePreview":null,"media":null,"type":"step"}]}]},{"featuredEyebrow":"Tutorial","title":"Customize views to fit your application","action":{"overridingTitle":"Get started","type":"reference","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"isActive":true,"identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/CustomizingViews"},"kind":"callToAction","abstract":[{"type":"text","text":"Learn how to customize your view to fit your applications profile."},{"type":"text","text":" "},{"type":"text","text":"Customize loading, preloading and error views."}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/tws\/notifications"]}],"kind":"project","identifier":{"url":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","interfaceLanguage":"swift"},"references":{"doc://tws-ios.TWS/tutorials/TWS/Notifications":{"abstract":[{"text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base.","type":"text"}],"type":"topic","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications","role":"project"