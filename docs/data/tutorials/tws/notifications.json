                 fetchCompletionHandler completionHandler: @escaping (UIBackgroundFetchResult) -> Void) {","        ","        if TWSNotification().handleTWSPushNotification(userInfo) {","            return","        }","        ","    }","    ","    ","    \/\/ ...","}"],"fileName":"ApplicationDelegate.swift","highlights":[],"type":"file","identifier":"Notifications_00.swift","syntax":"swift"},"doc://tws-ios.TWS/tutorials/TWS/MixAndMatch":{"type":"topic","role":"project","estimatedTime":"5min","url":"\/tutorials\/tws\/mixandmatch","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/MixAndMatch","title":"Combine remote and local snippets","abstract":[{"text":"Once you start mixing remote and local snippets, there are a few important considerations to keep in mind. Since the manager is injected into the environment, it can be accessed from anywhere in the app. However, this setup assumes that snippets are handled remotely. To successfully work with both remote and local snippets, you’ll need to follow specific rules and best practices.","type":"text"}],"kind":"project"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation":{"role":"project","url":"\/tutorials\/tws\/managercreation","kind":"project","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"type":"topic","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","estimatedTime":"5min","title":"Creating and managing TWSManager"},"doc://tws-ios.TWS/tutorials/TWS/Notifications#Integrating-TWSNotifications":{"url":"\/tutorials\/tws\/notifications#Integrating-TWSNotifications","abstract":[{"type":"text","text":"In this tutorial you will learn how to easily integrate TWSNotifications in your existing push notification code base."}],"kind":"section","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/Notifications#Integrating-TWSNotifications","title":"Integrating TWSNotifications","type":"section","role":"pseudoSymbol"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet":