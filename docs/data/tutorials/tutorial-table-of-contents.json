d use them in native flows"}],"estimatedTime":"5min","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/ManagerCreation":{"title":"Creating and managing TWSManager","role":"project","url":"\/tutorials\/tws\/managercreation","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/ManagerCreation","kind":"project","abstract":[{"type":"text","text":"Learn different ways of creating and managing TWSManager"}],"estimatedTime":"5min","type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/LocalSnippet":{"title":"Display your first local snippet","role":"project","url":"\/tutorials\/tws\/localsnippet","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/LocalSnippet","kind":"project","abstract":[{"type":"text","text":"Learn how to work with TWS snippets locally without connecting to our backend service. This tutorial will guide you through the steps to display a webpage snippet in your app, bypassing the backend, and focusing solely on rendering and showcasing the snippet content."}],"estimatedTime":"2min","type":"topic"},"doc://tws-ios.TWS/tutorials/Tutorial-Table-of-Contents":{"title":"Getting Started","role":"overview","url":"\/tutorials\/tutorial-table-of-contents","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/Tutorial-Table-of-Contents","kind":"overview","abstract":[{"type":"text","text":"Follow the tutorials to learn how to use the SDK for displaying snippets."}],"type":"topic"},"doc://tws-ios.TWS/tutorials/TWS/RemoteSnippet":{"title":"Display your first remote snippet","role":"project","kind":"project","identifier":"doc:\/\/tws-ios.TWS\/tutorials\/TWS\/RemoteSnippet","url":"\/tutorials\/tws\/remotesnippet","abstract":[{"text":"Learn how to set up a manager to handle the logic and functionality of your snippets, as well as how to seamlessly integrate them into your SwiftUI views.","type":"text"}],"estimatedTime":"3min","type":"topic"}}}