":2,"anchor":"Usage","text":"Usage"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can provide a custom implementation of this protocol and inject it into the "},{"type":"reference","identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView","isActive":true},{"type":"text","text":" using the appropriate configuration or environment modifier."}]},{"type":"heading","level":3,"anchor":"Example","text":"Example"},{"type":"codeListing","syntax":"swift","code":["final class CustomInterceptor: TWSViewInterceptor {","    func handleIntercept(_ url: TWSIntercepted) -> Bool {","        if url.host == \"native.example.com\" {","            \/\/ Handle URL natively","            print(\"Intercepted and handled natively: \\(url)\")","            return true","        }","        \/\/ Allow other URLs to load in the web view","        return false","    }","}","","struct ContentView: View {","    var body: some View {","        TWSView()","            .twsBind(interceptor: CustomInterceptor())","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This setup enables fine-grained control over URL navigation behavior within the "},{"type":"reference","identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView","isActive":true},{"type":"text","text":"."}]}]}],"identifier":{"url":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSViewInterceptor","interfaceLanguage":"swift"},"relationshipsSections":[{"kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/tws-ios.TWS\/s8SendableP","doc:\/\/tws-ios.TWS\/s16SendableMetatypeP"],"type":"inheritsFrom"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/tws\/twsviewinterceptor"]}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TWSViewInterceptor"}],"title":"TWSViewInterceptor","symbolKind":"protocol","roleHeading":"Protocol",