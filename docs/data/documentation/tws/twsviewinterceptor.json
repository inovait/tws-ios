{"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/tws\/twsviewinterceptor"]}],"abstract":[{"text":"A protocol that provides an interface for intercepting and handling URL navigation within a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView","type":"reference"},{"text":".","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TWSViewInterceptor","kind":"identifier"},{"text":" : AnyObject, ","kind":"text"},{"text":"Sendable","kind":"typeIdentifier","preciseIdentifier":"s:s8SendableP"}],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"mentions","mentions":["doc:\/\/tws-ios.TWS\/documentation\/TWS\/01_Customizations"]},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"This protocol enables custom navigation behavior by allowing you to intercept URLs before they are loaded in the web view. Implementing this protocol allows you to decide whether a specific URL should be loaded by the web view or handled natively within your application."}],"type":"paragraph"},{"level":2,"text":"Key Features","anchor":"Key-Features","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Prevent the web view from loading specific URLs."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle navigation natively for custom schemes, domains, or specific paths."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enhance user experience by integrating native features seamlessly."}]}]}],"type":"unorderedList"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"R