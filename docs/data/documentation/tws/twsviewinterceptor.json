{"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"abstract":[{"type":"text","text":"A protocol that provides an interface for intercepting and handling URL navigation within a "},{"type":"reference","identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView","isActive":true},{"type":"text","text":"."}],"topicSections":[{"title":"Instance Methods","generated":true,"anchor":"Instance-Methods","identifiers":["doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSViewInterceptor\/handleIntercept(_:)"]}],"kind":"symbol","relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/tws-ios.TWS\/s8SendableP"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","text":"MainActor","preciseIdentifier":"s:ScM"},{"kind":"text","text":" "},{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"TWSViewInterceptor"},{"kind":"text","text":" : AnyObject, "},{"kind":"typeIdentifier","text":"Sendable","preciseIdentifier":"s:s8SendableP"}]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"This protocol enables custom navigation behavior by allowing you to intercept URLs before they are loaded in the web view. Implementing this protocol allows you to decide whether a specific URL should be loaded by the web view or handled natively within your application."}],"type":"paragraph"},{"text":"Key Features","anchor":"Key-Features","level":2,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Prevent the web view from loading specific URLs.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle navigation natively for custom schemes, domains, or specific paths."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enhance user experience by integrating native features seamlessly."}]}]}],"type":"unorderedList"},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returning "},{"type":"codeVoice","code":"true"},{"type":"text","text":" from the "},{"type":"codeVoice","code":"handleIntercept(_:)"},{"type":"text","text":" method will prevent the web view from loading the intercepted URL."}]}],"type":"aside"},{"text":"Usage","anchor":"Usage","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"You can provide a custom implementation of this protocol and inject it into the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView"},{"type":"text","text":" using the appropriate configuration or environment modifier."}],"type":"paragraph"},{"text":"Example","anchor":"Example","level":3,"type":"heading"},{"code":["final class CustomInterceptor: TWSViewInterceptor {","    func handleIntercept(_ url: TWSIntercepted) -> Bool {","        if url.host == \"native.example.com\" {","            \/\/ Handle URL natively","            print(\"Intercepted and handled natively: \\(url)\")","            return true","        }","        \/\/ Allow other URLs to load in the web view","        return false","    }","}","","struct ContentView: View {","    var body: some View {","        TWSView()","            .twsBind(interceptor: CustomInterceptor())","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This setup enables fine-grained control over URL navigation behavior within the "},{"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/tws-ios.TWS\/documentation\/TWS"]]},"variants":[{"paths":["\/documentation\/tws\/twsviewinterceptor"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"in