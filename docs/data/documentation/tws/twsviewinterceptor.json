{"abstract":[{"type":"text","text":"A protocol that provides an interface for intercepting and handling URL navigation within a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView"},{"type":"text","text":"."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/tws\/twsviewinterceptor"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","sections":[],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/tws-ios.TWS\/s8SendableP"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TWSViewInterceptor","kind":"identifier"},{"text":" : AnyObject, ","kind":"text"},{"preciseIdentifier":"s:s8SendableP","text":"Sendable","kind":"typeIdentifier"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This protocol enables custom navigation behavior by allowing you to intercept URLs before they are loaded in the web view. Implementing this protocol allows you to decide whether a specific URL should be loaded by the web view or handled natively within your application."}]},{"type":"heading","level":2,"text":"Key Features","anchor":"Key-Features"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Prevent the web view from loading specific URLs.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Handle navigation natively for custom schemes, domains, or specific paths."}]}]},{"content":[{"inlineContent":[{"text":"Enhance user experience by integrating native features seamlessly.","type":"text"}],"type":"paragraph"}]}]},{"type":"aside","name":"Note","content":[{"inlineContent":[{"text":"Returning ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" from the ","type":"text"},{"type":"codeVoice","code":"handleIntercept(_:)"},{"text":" method will prevent the web view from loading the intercepted URL.","type":"text"}],"type":"paragraph"}],"style":"note"},{"type":"heading","level":2,"text":"Usage","anchor":"Usage"},{"type":"paragraph","inlineContent":[{"text":"You can provide a custom implementation of this protocol and inject it into the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView","type":"reference"},{"text":" using the appropriate configuration or environment modifier.","type":"text"}]},{"type":"heading","level":3,"text":"Example","anchor":"Example"},{"type":"codeListing","code":["final class CustomInterceptor: TWSViewInterceptor {","    func handleIntercept(_ url: TWSIntercepted) -> Bool {","        if url.host == \"native.example.com\" {","            \/\/ Handle URL natively","            print(\"Intercepted and handled natively: \\(url)\")","            return true","        }","        \/\/ Allow other URLs to load in the web view","        return false","    }","}","","struct ContentView: View {","    var body: some View {","        TWSView()","            .twsBind(interceptor: CustomInterceptor())","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This setup enables fine-grained control over URL navigation behavior within the "},{"identifier":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSView","isActive":true,"type":"reference"},{"text":".","type":"text"}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSViewInterceptor"},"topicSections":[{"generated":true,"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/tws-ios.TWS\/documentation\/TWS\/TWSViewInterceptor